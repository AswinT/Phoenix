<script>
// Modern Product Form Validation and Functionality

// Modern Form Validator Class
class ModernProductFormValidator {
    constructor() {
        this.requiredFields = ['name', 'modelNumber', 'category', 'color', 'brand', 'driverSize', 'connectivity', 'regularPrice', 'salePrice', 'description'];
        this.setupEventListeners();
        this.initializeCharacterCount();
    }

    setupEventListeners() {
        // Add blur event listeners for validation
        this.requiredFields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (field) {
                field.addEventListener('blur', () => this.validateField(field));
                field.addEventListener('input', () => this.clearError(fieldName));
            }
        });

        // Form submission
        const form = document.getElementById('productForm');
        if (form) {
            form.addEventListener('submit', (e) => this.handleSubmit(e));
        }
    }

    validateField(field) {
        const fieldName = field.name || field.id;
        const value = field.value.trim();
        let isValid = true;
        let errorMessage = '';

        // Clear previous error
        this.clearError(fieldName);

        switch (fieldName) {
            case 'name':
                if (!value) {
                    errorMessage = 'Product name is required';
                    isValid = false;
                } else if (!/^[a-zA-Z0-9\s\-\.\,\(\)]+$/.test(value)) {
                    errorMessage = 'Product name can only contain letters, numbers, spaces, and basic punctuation';
                    isValid = false;
                } else if (value.length < 3) {
                    errorMessage = 'Product name must be at least 3 characters long';
                    isValid = false;
                }
                break;

            case 'modelNumber':
                if (!value) {
                    errorMessage = 'Model number is required';
                    isValid = false;
                }
                break;

            case 'driverSize':
                if (!value) {
                    errorMessage = 'Driver size is required';
                    isValid = false;
                } else if (value === 'custom') {
                    // Validate custom driver size input
                    const customInput = document.getElementById('customDriverSize');
                    const customValue = customInput ? customInput.value.trim() : '';
                    if (!customValue) {
                        errorMessage = 'Please enter a custom driver size';
                        isValid = false;
                    } else if (!/^\d+(\.\d+)?\s*(mm|cm|inch|in)$/i.test(customValue)) {
                        errorMessage = 'Please enter a valid size with unit (e.g., 45mm, 1.8in)';
                        isValid = false;
                    }
                }
                break;

            case 'category':
            case 'color':
            case 'brand':
            case 'connectivity':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                }
                break;

            case 'regularPrice':
            case 'salePrice':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                } else if (isNaN(value) || parseFloat(value) <= 0) {
                    errorMessage = `${this.getFieldLabel(fieldName)} must be a positive number`;
                    isValid = false;
                }
                break;

            case 'stock':
                if (!value) {
                    errorMessage = 'Stock quantity is required';
                    isValid = false;
                } else if (isNaN(value) || parseInt(value) < 0) {
                    errorMessage = 'Stock quantity must be a non-negative number';
                    isValid = false;
                }
                break;

            case 'description':
                if (!value) {
                    errorMessage = 'Product description is required';
                    isValid = false;
                } else if (value.length < 10) {
                    errorMessage = 'Description must be at least 10 characters long';
                    isValid = false;
                } else if (value.length > 1000) {
                    errorMessage = 'Description must be less than 1000 characters';
                    isValid = false;
                }
                break;
        }

        if (!isValid) {
            this.showError(fieldName, errorMessage);
            field.classList.add('error');
        } else {
            field.classList.remove('error');
        }

        return isValid;
    }

    handleSubmit(event) {
        let isFormValid = true;

        // Validate all required fields
        this.requiredFields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (field && !this.validateField(field)) {
                isFormValid = false;
            }
        });

        // Additional validation for price comparison
        const regularPrice = parseFloat(document.getElementById('regularPrice').value);
        const salePrice = parseFloat(document.getElementById('salePrice').value);

        if (regularPrice && salePrice && salePrice > regularPrice) {
            this.showError('salePrice', 'Sale price cannot be higher than regular price');
            document.getElementById('salePrice').classList.add('error');
            isFormValid = false;
        }

        if (!isFormValid) {
            event.preventDefault();

            // Scroll to first error
            const firstError = document.querySelector('.form-input.error');
            if (firstError) {
                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                firstError.focus();
            }
        }
    }

    showError(fieldName, message) {
        const errorElement = document.getElementById(`${fieldName}-error`);
        if (errorElement) {
            errorElement.textContent = message;
            errorElement.style.display = 'flex';
        }
    }

    clearError(fieldName) {
        const errorElement = document.getElementById(`${fieldName}-error`);
        if (errorElement) {
            errorElement.textContent = '';
            errorElement.style.display = 'none';
        }

        const field = document.getElementById(fieldName);
        if (field) {
            field.classList.remove('error');
        }
    }

    getFieldLabel(fieldName) {
        const labels = {
            name: 'Product name',
            modelNumber: 'Model number',
            category: 'Category',
            color: 'Color',
            brand: 'Brand',
            driverSize: 'Driver size',
            connectivity: 'Connectivity',
            regularPrice: 'Regular price',
            salePrice: 'Sale price',
            stock: 'Stock quantity',
            description: 'Description'
        };
        return labels[fieldName] || fieldName;
    }

    initializeCharacterCount() {
        const descriptionField = document.getElementById('description');
        const countElement = document.getElementById('description-count');

        if (descriptionField && countElement) {
            const updateCount = () => {
                const count = descriptionField.value.length;
                countElement.textContent = count;

                if (count > 1000) {
                    countElement.style.color = '#dc2626';
                } else if (count > 800) {
                    countElement.style.color = '#f59e0b';
                } else {
                    countElement.style.color = '#666666';
                }
            };

            // Initial count
            updateCount();

            // Update on input
            descriptionField.addEventListener('input', updateCount);
        }
    }
}

// Driver Size Dropdown Handler
function handleDriverSizeChange(selectElement) {
    const customContainer = document.getElementById('customDriverSizeContainer');
    const customInput = document.getElementById('customDriverSize');

    if (selectElement.value === 'custom') {
        customContainer.style.display = 'block';
        customContainer.classList.add('show');
        customInput.focus();

        // Clear any existing validation errors on the select
        if (validator) {
            validator.clearError('driverSize');
        }
    } else {
        customContainer.style.display = 'none';
        customContainer.classList.remove('show');
        customInput.value = '';

        // Clear any custom input validation errors
        if (validator) {
            validator.clearError('driverSize');
        }
    }
}

// Initialize driver size on page load
function initializeDriverSize() {
    const driverSizeSelect = document.getElementById('driverSize');
    const customContainer = document.getElementById('customDriverSizeContainer');
    const customInput = document.getElementById('customDriverSize');

    // Check if we have a custom value from server-side validation
    if (customInput && customInput.value.trim() !== '') {
        driverSizeSelect.value = 'custom';
        customContainer.style.display = 'block';
        customContainer.classList.add('show');
    }

    // Add event listener to custom input for validation
    if (customInput) {
        customInput.addEventListener('blur', function() {
            if (driverSizeSelect.value === 'custom' && validator) {
                validator.validateField(driverSizeSelect);
            }
        });

        customInput.addEventListener('input', function() {
            if (driverSizeSelect.value === 'custom' && validator) {
                validator.clearError('driverSize');
            }
        });
    }
}

// Modern Image Upload Handler
function initializeImageUpload() {
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('imageInput');
    const uploadedImagesContainer = document.getElementById('uploadedImages');

    if (!uploadArea || !fileInput) return;

    // Drag and drop handlers
    uploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadArea.classList.add('dragover');
    });

    uploadArea.addEventListener('dragleave', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
    });

    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');

        const files = Array.from(e.dataTransfer.files);
        handleFiles(files);
    });

    // Click to upload
    uploadArea.addEventListener('click', () => {
        fileInput.click();
    });

    // File input change
    fileInput.addEventListener('change', (e) => {
        const files = Array.from(e.target.files);
        handleFiles(files);
    });

    function handleFiles(files) {
        // Filter image files
        const imageFiles = files.filter(file => file.type.startsWith('image/'));

        if (imageFiles.length === 0) {
            alert('Please select valid image files.');
            return;
        }

        if (imageFiles.length > 5) {
            alert('You can upload maximum 5 images.');
            return;
        }

        // Clear previous uploads
        uploadedImagesContainer.innerHTML = '';

        // Process each file
        imageFiles.forEach((file, index) => {
            if (file.size > 5 * 1024 * 1024) { // 5MB limit
                alert(`File ${file.name} is too large. Maximum size is 5MB.`);
                return;
            }

            const reader = new FileReader();
            reader.onload = (e) => {
                createImagePreview(e.target.result, file.name, index);
            };
            reader.readAsDataURL(file);
        });
    }

    function createImagePreview(src, name, index) {
        const previewDiv = document.createElement('div');
        previewDiv.className = 'image-preview-item';
        previewDiv.innerHTML = `
            <img src="${src}" alt="${name}" class="preview-image">
            <div class="preview-info">
                <span class="preview-name">${name}</span>
                <button type="button" class="remove-btn" onclick="removeImage(this)">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        `;

        uploadedImagesContainer.appendChild(previewDiv);
    }
}

function removeImage(button) {
    const previewItem = button.closest('.image-preview-item');
    if (previewItem) {
        previewItem.remove();
    }
}

// Image Deletion Functionality
let currentDeleteData = null;

function confirmImageDeletion(imageIndex, imageUrl, isMain) {
    const currentImages = document.querySelectorAll('.current-image-item');
    const totalCurrentImages = currentImages.length;
    const uploadedImages = document.querySelectorAll('#uploadedImages .image-preview-item');
    const totalUploadedImages = uploadedImages.length;
    const totalImages = totalCurrentImages + totalUploadedImages;

    // Store deletion data
    currentDeleteData = {
        index: parseInt(imageIndex),
        url: imageUrl,
        isMain: isMain === 'true' || isMain === true
    };

    // Show modal
    const modal = document.getElementById('deleteImageModal');
    const preview = document.getElementById('deleteImagePreview');
    const mainWarning = document.getElementById('mainImageWarning');
    const minimumWarning = document.getElementById('minimumWarning');
    const confirmBtn = document.getElementById('confirmDeleteBtn');

    preview.src = imageUrl;

    // Show/hide warnings
    if (currentDeleteData.isMain) {
        mainWarning.style.display = 'flex';
    } else {
        mainWarning.style.display = 'none';
    }

    // Check minimum image requirement
    if (totalImages <= 3) {
        minimumWarning.style.display = 'flex';
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Cannot Delete';
    } else {
        minimumWarning.style.display = 'none';
        confirmBtn.disabled = false;
        confirmBtn.innerHTML = '<i class="bi bi-trash"></i> Delete Image';
    }

    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeDeleteModal() {
    const modal = document.getElementById('deleteImageModal');
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
    currentDeleteData = null;
}

async function deleteImage() {
    if (!currentDeleteData) return;

    const imageItem = document.querySelector(`[data-image-index="${currentDeleteData.index}"]`);
    const loadingOverlay = imageItem.querySelector('.loading-overlay');

    try {
        // Show loading state
        loadingOverlay.style.display = 'flex';
        closeDeleteModal();

        // Make API call to delete image
        const response = await fetch(`/admin/products/<%= product._id %>/images/${currentDeleteData.index}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        const result = await response.json();

        if (result.success) {
            // Remove image from DOM
            imageItem.remove();

            // Update image count
            updateImageCount();

            // Reassign indices to remaining images
            reassignImageIndices();

            // Show success toast
            showToast('success', 'Image deleted successfully');

            // If main image was deleted, update the new main image badge
            if (currentDeleteData.isMain) {
                updateMainImageBadge();
            }
        } else {
            // Hide loading and show error
            loadingOverlay.style.display = 'none';
            showToast('error', result.message || 'Failed to delete image');
        }
    } catch (error) {
        console.error('Error deleting image:', error);
        loadingOverlay.style.display = 'none';
        showToast('error', 'An error occurred while deleting the image');
    }
}

function setAsMainImage(imageIndex) {
    const imageItems = document.querySelectorAll('.current-image-item');
    const targetItem = document.querySelector(`[data-image-index="${imageIndex}"]`);

    if (!targetItem) return;

    // Show loading state
    const loadingOverlay = targetItem.querySelector('.loading-overlay');
    loadingOverlay.style.display = 'flex';

    // Make API call to set as main image
    fetch(`/admin/products/<%= product._id %>/images/${imageIndex}/set-main`, {
        method: 'PATCH',
        headers: {
            'Content-Type': 'application/json',
        }
    })
    .then(response => response.json())
    .then(result => {
        loadingOverlay.style.display = 'none';

        if (result.success) {
            // Remove main badge from all images
            imageItems.forEach(item => {
                const badge = item.querySelector('.main-badge');
                const mainBtn = item.querySelector('.main-btn');
                if (badge) badge.remove();
                if (mainBtn) mainBtn.style.display = 'block';
                item.setAttribute('data-is-main', 'false');
            });

            // Add main badge to selected image
            const imageContainer = targetItem.querySelector('.image-container');
            const mainBadge = document.createElement('div');
            mainBadge.className = 'main-badge';
            mainBadge.innerHTML = '<i class="bi bi-star-fill"></i> Main';
            imageContainer.appendChild(mainBadge);

            // Hide main button for this image
            const mainBtn = targetItem.querySelector('.main-btn');
            if (mainBtn) mainBtn.style.display = 'none';

            targetItem.setAttribute('data-is-main', 'true');

            showToast('success', 'Main image updated successfully');
        } else {
            showToast('error', result.message || 'Failed to update main image');
        }
    })
    .catch(error => {
        console.error('Error setting main image:', error);
        loadingOverlay.style.display = 'none';
        showToast('error', 'An error occurred while updating the main image');
    });
}

function updateImageCount() {
    const currentImages = document.querySelectorAll('.current-image-item');
    const countElement = document.getElementById('currentImageCount');
    if (countElement) {
        countElement.textContent = currentImages.length;
    }
}

function reassignImageIndices() {
    const imageItems = document.querySelectorAll('.current-image-item');
    imageItems.forEach((item, index) => {
        item.setAttribute('data-image-index', index);

        // Update onclick handlers
        const deleteBtn = item.querySelector('.delete-btn');
        const mainBtn = item.querySelector('.main-btn');

        if (deleteBtn) {
            const imageUrl = item.getAttribute('data-image-url');
            const isMain = item.getAttribute('data-is-main') === 'true';
            deleteBtn.setAttribute('onclick', `confirmImageDeletion('${index}', '${imageUrl}', ${isMain})`);
        }

        if (mainBtn) {
            mainBtn.setAttribute('onclick', `setAsMainImage('${index}')`);
        }
    });
}

function updateMainImageBadge() {
    const imageItems = document.querySelectorAll('.current-image-item');
    if (imageItems.length > 0) {
        const firstItem = imageItems[0];
        const imageContainer = firstItem.querySelector('.image-container');

        // Add main badge to first image
        const mainBadge = document.createElement('div');
        mainBadge.className = 'main-badge';
        mainBadge.innerHTML = '<i class="bi bi-star-fill"></i> Main';
        imageContainer.appendChild(mainBadge);

        // Hide main button for first image
        const mainBtn = firstItem.querySelector('.main-btn');
        if (mainBtn) mainBtn.style.display = 'none';

        firstItem.setAttribute('data-is-main', 'true');
    }
}

function showToast(type, message) {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;

    const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';

    toast.innerHTML = `
        <i class="toast-icon bi ${icon}"></i>
        <span class="toast-message">${message}</span>
        <button class="toast-close" onclick="removeToast(this)">
            <i class="bi bi-x"></i>
        </button>
    `;

    container.appendChild(toast);

    // Auto remove after 5 seconds
    setTimeout(() => {
        if (toast.parentNode) {
            removeToast(toast.querySelector('.toast-close'));
        }
    }, 5000);
}

function removeToast(button) {
    const toast = button.closest('.toast');
    if (toast) {
        toast.style.animation = 'toastSlideOut 0.3s ease forwards';
        setTimeout(() => {
            if (toast.parentNode) {
                toast.remove();
            }
        }, 300);
    }
}

// Add toast slide out animation
const style = document.createElement('style');
style.textContent = `
    @keyframes toastSlideOut {
        from {
            opacity: 1;
            transform: translateX(0);
        }
        to {
            opacity: 0;
            transform: translateX(100%);
        }
    }
`;
document.head.appendChild(style);

// Initialize validator when DOM is loaded
let validator;
document.addEventListener('DOMContentLoaded', function() {
    validator = new ModernProductFormValidator();
    initializeDriverSize();
    initializeImageUpload();

    // Close modal when clicking outside
    document.getElementById('deleteImageModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeDeleteModal();
        }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteModal();
        }
    });
});
</script>
