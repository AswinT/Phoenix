</style>

<!-- Include Cropper.js for image cropping -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>

<script>
// Modern Form Validation and Image Handling
class ModernProductFormValidator {
    constructor() {
        this.form = document.getElementById('productForm');
        this.submitBtn = document.getElementById('submitBtn');
        this.cropper = null;
        this.currentImageIndex = null;
        this.uploadedImages = [];
        this.maxImages = 5;
        this.minImages = 3;

        // Image upload elements
        this.uploadZone = document.getElementById('uploadZone');
        this.imageInput = document.getElementById('imageInput');
        this.previewGrid = document.getElementById('imagePreviewGrid');
        this.uploadCounter = document.getElementById('upload-counter');

        this.init();
    }

    init() {
        this.setupEventListeners();
        this.updateCharacterCount();
        this.updateUploadCounter();
        // Don't validate form on init - button should be enabled by default
    }

    setupEventListeners() {
        // Form validation only on blur and submit
        const inputs = this.form.querySelectorAll('.form-input');
        inputs.forEach(input => {
            // Only validate on blur (when user leaves field)
            input.addEventListener('blur', (e) => {
                this.validateField(e.target);
            });

            // Clear errors on input (when user starts typing)
            input.addEventListener('input', (e) => {
                this.clearError(e.target.id);
            });
        });

        // Form submission with validation
        this.form.addEventListener('submit', (e) => {
            e.preventDefault();
            this.handleSubmit();
        });

        // Description character count
        const description = document.getElementById('description');
        description.addEventListener('input', () => {
            this.updateCharacterCount();
        });

        // Image upload event listeners
        this.setupImageUpload();
    }

    setupImageUpload() {
        // Click to browse
        this.uploadZone.addEventListener('click', () => {
            if (this.uploadedImages.length < this.maxImages) {
                this.imageInput.click();
            }
        });

        // Browse link click
        const browseLink = this.uploadZone.querySelector('.browse-link');
        if (browseLink) {
            browseLink.addEventListener('click', (e) => {
                e.stopPropagation();
                if (this.uploadedImages.length < this.maxImages) {
                    this.imageInput.click();
                }
            });
        }

        // File input change
        this.imageInput.addEventListener('change', (e) => {
            this.handleFileSelect(e.target.files);
        });

        // Drag and drop
        this.uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            this.uploadZone.classList.add('drag-over');
        });

        this.uploadZone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            this.uploadZone.classList.remove('drag-over');
        });

        this.uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            this.uploadZone.classList.remove('drag-over');
            this.handleFileSelect(e.dataTransfer.files);
        });
    }

    handleFileSelect(files) {
        const fileArray = Array.from(files);

        // Check if adding these files would exceed the limit
        if (this.uploadedImages.length + fileArray.length > this.maxImages) {
            this.showError('images', `Maximum ${this.maxImages} images allowed`);
            return;
        }

        fileArray.forEach(file => {
            if (this.uploadedImages.length < this.maxImages) {
                this.addImage(file);
            }
        });
    }

    addImage(file) {
        // Validate file type
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
            this.showError('images', 'Only JPG, PNG, and WEBP files are allowed');
            return;
        }

        // Validate file size (max 5MB)
        if (file.size > 5 * 1024 * 1024) {
            this.showError('images', 'File size must be less than 5MB');
            return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
            const imageData = {
                file: file,
                url: e.target.result,
                id: Date.now() + Math.random(),
                isCropped: false // Track cropping state - MANDATORY cropping required
            };

            this.uploadedImages.push(imageData);
            this.renderImagePreview();
            this.updateUploadCounter();
            this.updateHiddenInputs();

            // Show mandatory cropping message immediately after upload
            this.showMandatoryCroppingMessage();

            // Auto-open crop modal for the newly uploaded image (optional UX enhancement)
            const newImageIndex = this.uploadedImages.length - 1;
            setTimeout(() => {
                this.cropImage(newImageIndex);
            }, 500); // Small delay to allow rendering
        };
        reader.readAsDataURL(file);
    }

    renderImagePreview() {
        if (this.uploadedImages.length === 0) {
            this.previewGrid.style.display = 'none';
            return;
        }

        this.previewGrid.style.display = 'grid';
        this.previewGrid.innerHTML = '';

        this.uploadedImages.forEach((image, index) => {
            const previewItem = document.createElement('div');
            let className = 'image-preview-item';
            if (index === 0) className += ' main-image';
            if (image.isCropped) {
                className += ' cropped';
            } else {
                className += ' uncropped';
            }
            previewItem.className = className;
            previewItem.draggable = true;
            previewItem.dataset.index = index;

            previewItem.innerHTML = `
                <img src="${image.url}" alt="Preview ${index + 1}" class="preview-image">
                <div class="image-overlay">
                    <button type="button" class="overlay-btn crop-btn" onclick="validator.cropImage(${index})">
                        <i class="bi bi-crop"></i>
                    </button>
                    <button type="button" class="overlay-btn remove-btn" onclick="validator.removeImage(${index})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <div class="drag-handle">
                    <i class="bi bi-grip-vertical"></i>
                </div>
            `;

            // Add drag and drop for reordering
            previewItem.addEventListener('dragstart', (e) => {
                e.dataTransfer.setData('text/plain', index);
            });

            previewItem.addEventListener('dragover', (e) => {
                e.preventDefault();
            });

            previewItem.addEventListener('drop', (e) => {
                e.preventDefault();
                const draggedIndex = parseInt(e.dataTransfer.getData('text/plain'));
                const targetIndex = parseInt(e.currentTarget.dataset.index);
                this.reorderImages(draggedIndex, targetIndex);
            });

            this.previewGrid.appendChild(previewItem);
        });
    }

    reorderImages(fromIndex, toIndex) {
        if (fromIndex === toIndex) return;

        const movedImage = this.uploadedImages.splice(fromIndex, 1)[0];
        this.uploadedImages.splice(toIndex, 0, movedImage);

        this.renderImagePreview();
        this.updateHiddenInputs();
    }

    removeImage(index) {
        this.uploadedImages.splice(index, 1);
        this.renderImagePreview();
        this.updateUploadCounter();
        this.updateHiddenInputs();
        this.clearError('images');
    }

    cropImage(index) {
        this.currentImageIndex = index;
        const image = this.uploadedImages[index];

        const cropModal = document.getElementById('cropModal');
        const cropImage = document.getElementById('cropImage');

        cropImage.src = image.url;
        cropModal.style.display = 'flex';

        // Initialize cropper
        setTimeout(() => {
            if (this.cropper) {
                this.cropper.destroy();
            }
            this.cropper = new Cropper(cropImage, {
                aspectRatio: 1,
                viewMode: 1,
                autoCropArea: 0.8,
                responsive: true,
                background: false
            });
        }, 100);
    }

    updateUploadCounter() {
        const count = this.uploadedImages.length;
        const croppedCount = this.uploadedImages.filter(img => img.isCropped).length;
        const uncroppedCount = count - croppedCount;

        let counterText = `${count}/${this.maxImages} images uploaded`;
        if (count > 0) {
            if (uncroppedCount > 0) {
                counterText += ` • ${uncroppedCount} need cropping`;
            } else {
                counterText += ` • All cropped ✓`;
            }
        }

        this.uploadCounter.textContent = counterText;

        // Update upload zone visibility
        if (count >= this.maxImages) {
            this.uploadZone.style.display = 'none';
        } else {
            this.uploadZone.style.display = 'block';
        }
    }

    updateHiddenInputs() {
        // Clear all hidden inputs first
        for (let i = 0; i < this.maxImages; i++) {
            const hiddenInput = document.getElementById(`hiddenImage${i}`);
            if (hiddenInput) {
                hiddenInput.value = '';
                hiddenInput.files = null;
            }
        }

        // Set files for uploaded images
        this.uploadedImages.forEach((image, index) => {
            const hiddenInput = document.getElementById(`hiddenImage${index}`);
            if (hiddenInput && image.file) {
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(image.file);
                hiddenInput.files = dataTransfer.files;
            }
        });
    }

    validateField(field) {
        const fieldName = field.name || field.id;
        const value = field.value.trim();
        let isValid = true;
        let errorMessage = '';

        // Clear previous error
        this.clearError(fieldName);

        switch (fieldName) {
            case 'name':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                } else if (value.length < 2) {
                    errorMessage = 'Must be at least 2 characters long';
                    isValid = false;
                }
                break;
                
            case 'color':
            case 'brand':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                } else if (!/^[A-Za-z\s\-'\.]+$/.test(value)) {
                    errorMessage = 'Only alphabetic characters, spaces, hyphens, and apostrophes allowed';
                    isValid = false;
                } else if (value.length < 2) {
                    errorMessage = 'Must be at least 2 characters long';
                    isValid = false;
                }
                break;



            case 'stock':
                if (!value) {
                    errorMessage = 'Stock quantity is required';
                    isValid = false;
                } else if (!/^\d+$/.test(value)) {
                    errorMessage = 'Must be a positive integer';
                    isValid = false;
                } else if (parseInt(value) < 0) {
                    errorMessage = 'Cannot be negative';
                    isValid = false;
                }
                break;

            case 'regularPrice':
            case 'salePrice':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                } else if (!/^\d+(\.\d{1,2})?$/.test(value)) {
                    errorMessage = 'Must be a positive number with up to 2 decimal places';
                    isValid = false;
                } else if (parseFloat(value) <= 0) {
                    errorMessage = 'Must be greater than 0';
                    isValid = false;
                }
                break;

            case 'description':
                if (!value) {
                    errorMessage = 'Description is required';
                    isValid = false;
                } else if (value.length < 10) {
                    errorMessage = 'Description must be at least 10 characters long';
                    isValid = false;
                }
                break;

            case 'category':
            case 'connectivity':
                if (!value) {
                    errorMessage = `Please select a ${fieldName}`;
                    isValid = false;
                }
                break;

            case 'modelNumber':
                if (!value) {
                    errorMessage = `${this.getFieldLabel(fieldName)} is required`;
                    isValid = false;
                }
                break;

            case 'driverSize':
                if (!value) {
                    errorMessage = 'Driver size is required';
                    isValid = false;
                } else if (value === 'custom') {
                    // Validate custom driver size input
                    const customInput = document.getElementById('customDriverSize');
                    const customValue = customInput ? customInput.value.trim() : '';
                    if (!customValue) {
                        errorMessage = 'Please enter a custom driver size';
                        isValid = false;
                    } else if (!/^\d+(\.\d+)?\s*(mm|cm|inch|in)$/i.test(customValue)) {
                        errorMessage = 'Please enter a valid size with unit (e.g., 45mm, 1.8in)';
                        isValid = false;
                    }
                }
                break;
        }

        // Additional validation for sale price vs regular price
        if (fieldName === 'salePrice' && isValid) {
            const regularPrice = parseFloat(document.getElementById('regularPrice').value);
            const salePrice = parseFloat(value);
            if (regularPrice && salePrice > regularPrice) {
                errorMessage = 'Sale price cannot be higher than regular price';
                isValid = false;
            }
        }

        if (!isValid) {
            this.showError(fieldName, errorMessage);
            field.classList.add('error');
        } else {
            field.classList.remove('error');
            field.classList.add('success');
            setTimeout(() => field.classList.remove('success'), 2000);
        }

        return isValid;
    }

    validateImages() {
        const imageCount = this.uploadedImages.length;
        const uncroppedImages = this.uploadedImages.filter(img => !img.isCropped);
        const uncroppedCount = uncroppedImages.length;

        let isValid = true;
        let errorMessage = '';

        // Check minimum image count first
        if (imageCount < this.minImages) {
            isValid = false;
            errorMessage = `Please upload at least ${this.minImages} images (currently ${imageCount})`;
        }
        // MANDATORY: Check if all images are cropped - this is now required
        else if (uncroppedCount > 0) {
            isValid = false;
            if (uncroppedCount === 1) {
                errorMessage = `⚠️ Cropping is mandatory! Please crop the remaining image before submitting`;
            } else {
                errorMessage = `⚠️ Cropping is mandatory! Please crop all ${uncroppedCount} remaining images before submitting`;
            }
        }

        if (!isValid) {
            this.showError('images', errorMessage);
        } else {
            this.clearError('images');
        }

        return isValid;
    }

    showMandatoryCroppingMessage() {
        const uncroppedCount = this.uploadedImages.filter(img => !img.isCropped).length;
        if (uncroppedCount > 0) {
            if (uncroppedCount === 1) {
                this.showError('images', `⚠️ Image cropping is mandatory! Please crop the uploaded image to continue.`);
            } else {
                this.showError('images', `⚠️ Image cropping is mandatory! Please crop all ${uncroppedCount} uploaded images to continue.`);
            }
        }
    }

    validateForm() {
        const requiredFields = [
            'name', 'modelNumber', 'category', 'color', 'brand',
            'stock', 'driverSize', 'connectivity', 'regularPrice',
            'salePrice', 'description'
        ];

        let isFormValid = true;

        // Only validate fields that have been touched or on submit
        requiredFields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (field && field.value.trim() === '') {
                isFormValid = false;
            }
        });

        // Validate images
        if (!this.validateImages()) {
            isFormValid = false;
        }

        // Don't disable button by default - only on submit validation
        return isFormValid;
    }

    handleSubmit() {
        // Validate all fields on submit
        const requiredFields = [
            'name', 'modelNumber', 'category', 'color', 'brand',
            'stock', 'driverSize', 'connectivity', 'regularPrice',
            'salePrice', 'description'
        ];

        let isFormValid = true;

        // Validate all required fields and show errors
        requiredFields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (field && !this.validateField(field)) {
                isFormValid = false;
            }
        });

        // Validate images
        if (!this.validateImages()) {
            isFormValid = false;
        }

        if (isFormValid) {
            // Submit the form directly without animations
            this.form.submit();
        } else {
            // Scroll to first error
            const firstError = document.querySelector('.error-message.show');
            if (firstError) {
                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    }

    showError(fieldName, message) {
        const errorElement = document.getElementById(`${fieldName}-error`);
        if (errorElement) {
            errorElement.textContent = message;
            errorElement.classList.add('show');
        }
    }



    hideLoadingOverlay() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            overlay.classList.remove('show');
            // Restore scrolling
            document.body.style.overflow = '';
        }
    }

    clearError(fieldName) {
        const errorElement = document.getElementById(`${fieldName}-error`);
        if (errorElement) {
            errorElement.textContent = '';
            errorElement.classList.remove('show');
        }
    }

    getFieldLabel(fieldName) {
        const labels = {
            'name': 'Product name',
            'modelNumber': 'Model number',
            'color': 'Color',
            'brand': 'Brand',
            'stock': 'Stock quantity',
            'driverSize': 'Driver size',
            'regularPrice': 'Regular price',
            'salePrice': 'Sale price',
            'description': 'Description'
        };
        return labels[fieldName] || fieldName;
    }

    updateCharacterCount() {
        const description = document.getElementById('description');
        const counter = document.getElementById('description-count');
        if (description && counter) {
            counter.textContent = description.value.length;
            counter.style.color = description.value.length >= 10 ? '#28a745' : '#dc3545';
        }
    }
}

// Driver Size Dropdown Handler
function handleDriverSizeChange(selectElement) {
    const customContainer = document.getElementById('customDriverSizeContainer');
    const customInput = document.getElementById('customDriverSize');

    if (selectElement.value === 'custom') {
        customContainer.style.display = 'block';
        customContainer.classList.add('show');
        customInput.focus();

        // Clear any existing validation errors on the select
        validator.clearError('driverSize');
    } else {
        customContainer.style.display = 'none';
        customContainer.classList.remove('show');
        customInput.value = '';

        // Clear any custom input validation errors
        validator.clearError('driverSize');
    }
}

// Initialize driver size on page load
function initializeDriverSize() {
    const driverSizeSelect = document.getElementById('driverSize');
    const customContainer = document.getElementById('customDriverSizeContainer');
    const customInput = document.getElementById('customDriverSize');

    // Check if we have a custom value from server-side validation
    if (customInput && customInput.value.trim() !== '') {
        driverSizeSelect.value = 'custom';
        customContainer.style.display = 'block';
        customContainer.classList.add('show');
    }

    // Add event listener to custom input for validation
    if (customInput) {
        customInput.addEventListener('blur', function() {
            if (driverSizeSelect.value === 'custom') {
                validator.validateField(driverSizeSelect);
            }
        });

        customInput.addEventListener('input', function() {
            if (driverSizeSelect.value === 'custom') {
                validator.clearError('driverSize');
            }
        });
    }
}

// Modern Crop Modal Functions
function closeCropModal() {
    const cropModal = document.getElementById('cropModal');
    cropModal.style.display = 'none';

    if (validator.cropper) {
        validator.cropper.destroy();
        validator.cropper = null;
    }
}

function applyCrop() {
    if (validator.cropper && validator.currentImageIndex !== null) {
        const canvas = validator.cropper.getCroppedCanvas({
            width: 400,
            height: 400,
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high'
        });

        const croppedDataUrl = canvas.toDataURL('image/jpeg', 0.9);

        // Update the image in the array
        validator.uploadedImages[validator.currentImageIndex].url = croppedDataUrl;
        validator.uploadedImages[validator.currentImageIndex].isCropped = true; // Mark as cropped

        // Convert canvas to blob and update file
        canvas.toBlob((blob) => {
            const file = new File([blob], `cropped-image-${validator.currentImageIndex}.jpg`, {
                type: 'image/jpeg'
            });

            validator.uploadedImages[validator.currentImageIndex].file = file;
            validator.renderImagePreview();
            validator.updateUploadCounter(); // Update counter to reflect cropping status
            validator.updateHiddenInputs();

            // Clear any cropping errors and show success message if all images are cropped
            const uncroppedCount = validator.uploadedImages.filter(img => !img.isCropped).length;
            if (uncroppedCount === 0) {
                validator.clearError('images');
                // Optional: Show brief success message
                setTimeout(() => {
                    const imageCount = validator.uploadedImages.length;
                    if (imageCount >= validator.minImages) {
                        validator.showError('images', `✅ All ${imageCount} images have been cropped successfully!`);
                        setTimeout(() => validator.clearError('images'), 3000);
                    }
                }, 100);
            } else {
                validator.showMandatoryCroppingMessage();
            }
        }, 'image/jpeg', 0.9);

        closeCropModal();
    }
}



// Initialize validator when DOM is loaded
let validator;
document.addEventListener('DOMContentLoaded', function() {
    validator = new ModernProductFormValidator();
    initializeDriverSize();
});

// Prevent form submission on Enter key (except in textarea)
document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
        e.preventDefault();
    }
});
</script>
