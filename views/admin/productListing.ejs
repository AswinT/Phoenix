<%- include('../partials/admin/_adminHeader.ejs') %>
<%- include("../partials/admin/_adminSidebar.ejs") %>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="admin-content">
    <div class="modern-admin-container">
        <!-- Page Header -->
        <div class="admin-page-header">
            <div class="header-content">
                <div class="header-left">
                    <h1 class="page-title">
                        <i class="bi bi-headphones"></i>
                        Product Management
                    </h1>
                    <p class="page-subtitle">Manage your Phoenix product inventory</p>
                </div>
                <div class="header-actions">
                    <a href="/admin/product/add" class="modern-btn modern-btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        Add New Product
                    </a>
                </div>
            </div>
        </div>

        <!-- Search and Filter Section -->
        <div class="admin-card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-funnel"></i>
                    Search & Filter
                </h3>
            </div>
            <div class="card-body">
                <div class="search-filter-container">
                    <div class="search-section">
                        <form action="/admin/products" method="GET" class="search-form">
                            <div class="search-group">
                                <div class="search-input-container">
                                    <i class="bi bi-search search-icon"></i>
                                    <input type="text"
                                           class="modern-input search-input"
                                           name="search"
                                           placeholder="Search products by name, brand, or category..."
                                           value="<%= searchQuery %>">
                                </div>
                                <button type="submit" class="modern-btn modern-btn-primary">
                                    <i class="bi bi-search"></i>
                                    Search
                                </button>
                                <% if (searchQuery) { %>
                                    <a href="/admin/products" class="modern-btn modern-btn-secondary">
                                        <i class="bi bi-x"></i>
                                        Clear
                                    </a>
                                <% } %>
                            </div>
                        </form>
                    </div>
                    <div class="filter-section">
                        <div class="filter-group">
                            <label class="filter-label">Category Filter</label>
                            <select class="modern-select" onchange="filterByCategory(this.value)">
                                <option value="">All Categories</option>
                                <% categories.forEach(category => { %>
                                    <option value="<%= category.name %>"
                                            <%= query.category === category.name ? 'selected' : '' %>>
                                        <%= category.name %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="filter-label">Brand Filter</label>
                            <select class="modern-select brand-filter-dropdown" onchange="filterByBrand(this.value)">
                                <option value="">All Brands</option>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand %>"
                                            <%= query.brand === brand ? 'selected' : '' %>>
                                        <%= brand %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon stat-icon-primary">
                        <i class="bi bi-headphones"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-list-ul"></i>
                    </div>
                </div>
                <div class="stat-body">
                    <div class="stat-value"><%= products.length %></div>
                    <div class="stat-label">Products Shown</div>
                    <div class="stat-description">Current view</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon stat-icon-success">
                        <i class="bi bi-eye"></i>
                    </div>
                    <div class="stat-trend stat-trend-up">
                        <i class="bi bi-arrow-up"></i>
                    </div>
                </div>
                <div class="stat-body">
                    <div class="stat-value"><%= products.filter(p => p.isActive).length %></div>
                    <div class="stat-label">Active Products</div>
                    <div class="stat-description">Visible to customers</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon stat-icon-secondary">
                        <i class="bi bi-eye-slash"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-dash"></i>
                    </div>
                </div>
                <div class="stat-body">
                    <div class="stat-value"><%= products.filter(p => !p.isActive).length %></div>
                    <div class="stat-label">Inactive Products</div>
                    <div class="stat-description">Hidden from customers</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon stat-icon-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div class="stat-trend <%= products.filter(p => p.stock <= 5).length > 0 ? 'stat-trend-down' : 'stat-trend-up' %>">
                        <% if (products.filter(p => p.stock <= 5).length > 0) { %>
                            <i class="bi bi-arrow-down"></i>
                        <% } else { %>
                            <i class="bi bi-check-circle"></i>
                        <% } %>
                    </div>
                </div>
                <div class="stat-body">
                    <div class="stat-value <%= products.filter(p => p.stock <= 5).length > 0 ? 'stat-value-warning' : '' %>">
                        <%= products.filter(p => p.stock <= 5).length %>
                    </div>
                    <div class="stat-label">Low Stock (≤5)</div>
                    <div class="stat-description">Needs attention</div>
                </div>
            </div>
        </div>

        <!-- Products Table --<div class="admin-card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-grid-3x3-gap"></i>
                    Product Inventory
                </h3>
                <div class="header-actions">
                    <div class="view-info">
                        <span class="view-label">
                            <i class="bi bi-table"></i>
                            Table View
                        </span>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <!-- Table View -->
                <div id="tableView" class="table-view">
                    <div class="table-container">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Details</th>
                                    <th>Pricing</th>
                                    <th>Stock</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (products && products.length > 0) { %>
                                    <% products.forEach((product, index) => { %>
                                        <% const mainImage = product.images.find(img => img.isMain) || product.images[0]; %>
                                        <tr class="table-row">
                                            <!-- Product Column -->
                                            <td class="product-cell">
                                                <div class="product-info">
                                                    <div class="product-image">
                                                        <img src="<%= mainImage?.url || '/images/products/demo-product.jpg' %>"
                                                             alt="<%= product.name %>"
                                                             class="product-thumbnail">
                                                    </div>
                                                    <div class="product-details">
                                                        <h4 class="product-name"><%= product.name %></h4>
                                                        <p class="product-model">Model: <%= product.modelNumber %></p>
                                                    </div>
                                                </div>
                                            </td>

                                            <!-- Details Column -->
                                            <td class="details-cell">
                                                <div class="product-meta">
                                                    <div class="meta-row">
                                                        <span class="meta-label">Brand:</span>
                                                        <span class="modern-badge badge-brand"><%= product.brand %></span>
                                                    </div>
                                                    <div class="meta-row">
                                                        <span class="meta-label">Category:</span>
                                                        <span class="modern-badge badge-category"><%= product.category %></span>
                                                    </div>
                                                    <div class="meta-row">
                                                        <span class="meta-label">Type:</span>
                                                        <div class="connectivity-info">
                                                            <% if (product.connectivity === 'Wireless' || product.connectivity === 'Bluetooth') { %>
                                                                <i class="bi bi-wifi connectivity-icon wireless"></i>
                                                            <% } else { %>
                                                                <i class="bi bi-cable connectivity-icon wired"></i>
                                                            <% } %>
                                                            <span><%= product.connectivity %></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>

                                            <!-- Pricing Column -->
                                            <td class="pricing-cell">
                                                <div class="price-container">
                                                    <div class="current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></div>
                                                    <% if (product.regularPrice && product.salePrice < product.regularPrice) { %>
                                                        <div class="original-price">₹<%= product.regularPrice.toLocaleString('en-IN') %></div>
                                                        <div class="discount-badge">
                                                            <%= Math.round(((product.regularPrice - product.salePrice) / product.regularPrice) * 100) %>% OFF
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>

                                            <!-- Stock Column -->
                                            <td class="stock-cell">
                                                <% if (product.stock <= 0) { %>
                                                    <span class="modern-badge badge-danger">
                                                        <i class="bi bi-x-circle"></i>
                                                        Out of Stock
                                                    </span>
                                                <% } else if (product.stock <= 5) { %>
                                                    <span class="modern-badge badge-warning">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        Low: <%= product.stock %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="modern-badge badge-success">
                                                        <i class="bi bi-check-circle"></i>
                                                        <%= product.stock %> units
                                                    </span>
                                                <% } %>
                                            </td>

                                            <!-- Status Column -->
                                            <td class="status-cell">
                                                <% if (product.isActive) { %>
                                                    <span class="modern-badge badge-success">
                                                        <i class="bi bi-eye"></i>
                                                        Active
                                                    </span>
                                                <% } else { %>
                                                    <span class="modern-badge badge-secondary">
                                                        <i class="bi bi-eye-slash"></i>
                                                        Inactive
                                                    </span>
                                                <% } %>
                                            </td>

                                            <!-- Actions Column -->
                                            <td class="actions-cell">
                                                <div class="action-group">
                                                    <a href="/admin/product/edit/<%= product._id %>"
                                                       class="action-btn btn-edit"
                                                       title="Edit Product">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>

                                                    <button type="button"
                                                            class="action-btn btn-toggle"
                                                            onclick="toggleProduct('<%= product._id %>', <%= !product.isActive %>)"
                                                            title="<%= product.isActive ? 'Deactivate' : 'Activate' %>">
                                                        <i class="bi bi-<%= product.isActive ? 'eye-slash' : 'eye' %>"></i>
                                                    </button>

                                                    <button type="button"
                                                            class="action-btn btn-delete"
                                                            onclick="deleteProduct('<%= product._id %>', '<%= product.name %>')"
                                                            title="Delete Product">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="empty-state-cell">
                                            <div class="empty-state">
                                                <div class="empty-icon">
                                                    <i class="bi bi-headphones"></i>
                                                </div>
                                                <h4 class="empty-title">No products found</h4>
                                                <p class="empty-description">
                                                    <% if (searchQuery) { %>
                                                        No products match your search criteria.
                                                        <a href="/admin/products" class="clear-search-link">Clear search</a> to see all products.
                                                    <% } else { %>
                                                        Start by adding your first product to get started.
                                                    <% } %>
                                                </p>
                                                <a href="/admin/product/add" class="modern-btn modern-btn-primary">
                                                    <i class="bi bi-plus-circle"></i>
                                                    Add First Product
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Grid View (Hidden by default) -->
                <div id="gridView" class="grid-view" style="display: none;">
                    <div class="products-grid">
                        <% if (products && products.length > 0) { %>
                            <% products.forEach((product, index) => { %>
                                <% const mainImage = product.images.find(img => img.isMain) || product.images[0]; %>
                                <div class="grid-card">
                                    <div class="grid-card-image">
                                        <img src="<%= mainImage?.url || '/images/products/demo-product.jpg' %>"
                                             alt="<%= product.name %>">
                                        <div class="grid-card-overlay">
                                            <div class="overlay-actions">
                                                <a href="/admin/product/edit/<%= product._id %>" class="overlay-btn" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button onclick="toggleProduct('<%= product._id %>', <%= !product.isActive %>)"
                                                        class="overlay-btn" title="<%= product.isActive ? 'Deactivate' : 'Activate' %>">
                                                    <i class="bi bi-<%= product.isActive ? 'eye-slash' : 'eye' %>"></i>
                                                </button>
                                                <button onclick="deleteProduct('<%= product._id %>', '<%= product.name %>')"
                                                        class="overlay-btn overlay-btn-delete" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="grid-card-content">
                                        <h4 class="grid-card-title"><%= product.name %></h4>
                                        <p class="grid-card-model"><%= product.modelNumber %></p>
                                        <div class="grid-card-meta">
                                            <span class="modern-badge badge-brand"><%= product.brand %></span>
                                            <span class="modern-badge badge-category"><%= product.category %></span>
                                        </div>
                                        <div class="grid-card-price">
                                            <span class="current-price">₹<%= product.salePrice.toLocaleString('en-IN') %></span>
                                            <% if (product.regularPrice && product.salePrice < product.regularPrice) { %>
                                                <span class="original-price">₹<%= product.regularPrice.toLocaleString('en-IN') %></span>
                                            <% } %>
                                        </div>
                                        <div class="grid-card-footer">
                                            <div class="stock-status">
                                                <% if (product.stock <= 0) { %>
                                                    <span class="modern-badge badge-danger">Out of Stock</span>
                                                <% } else if (product.stock <= 5) { %>
                                                    <span class="modern-badge badge-warning">Low: <%= product.stock %></span>
                                                <% } else { %>
                                                    <span class="modern-badge badge-success"><%= product.stock %></span>
                                                <% } %>
                                            </div>
                                            <div class="status-indicator">
                                                <% if (product.isActive) { %>
                                                    <span class="status-dot status-active"></span>
                                                <% } else { %>
                                                    <span class="status-dot status-inactive"></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="grid-empty-state">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-headphones"></i>
                                    </div>
                                    <h4 class="empty-title">No products found</h4>
                                    <p class="empty-description">
                                        <% if (searchQuery) { %>
                                            No products match your search criteria.
                                        <% } else { %>
                                            Start by adding your first product.
                                        <% } %>
                                    </p>
                                    <a href="/admin/product/add" class="modern-btn modern-btn-primary">
                                        <i class="bi bi-plus-circle"></i>
                                        Add First Product
                                    </a>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="pagination-container">
                <nav class="pagination-nav">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>&search=<%= searchQuery %>&category=<%= query.category %>&brand=<%= query.brand %>"
                           class="pagination-btn pagination-prev">
                            <i class="bi bi-chevron-left"></i>
                            Previous
                        </a>
                    <% } %>

                    <div class="pagination-numbers">
                        <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <a href="?page=<%= i %>&search=<%= searchQuery %>&category=<%= query.category %>&brand=<%= query.brand %>"
                               class="pagination-number <%= i === currentPage ? 'active' : '' %>">
                                <%= i %>
                            </a>
                        <% } %>
                    </div>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>&search=<%= searchQuery %>&category=<%= query.category %>&brand=<%= query.brand %>"
                           class="pagination-btn pagination-next">
                            Next
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    <% } %>
                </nav>
            </div>
        <% } %>
    </div>
</div>

<style>
/* SweetAlert2 Custom Styling for Phoenix Admin Theme */
.swal2-popup {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    border-radius: 12px !important;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15) !important;
}

.swal2-title {
    color: #000000 !important;
    font-weight: 600 !important;
    font-size: 1.5rem !important;
}

.swal2-content {
    color: #6c757d !important;
    font-size: 1rem !important;
}

.swal2-confirm {
    background-color: #000000 !important;
    border: none !important;
    border-radius: 8px !important;
    font-weight: 600 !important;
    padding: 0.75rem 1.5rem !important;
    transition: all 0.3s ease !important;
}

.swal2-confirm:hover {
    background-color: #333333 !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2) !important;
}

.swal2-cancel {
    background-color: #ffffff !important;
    color: #000000 !important;
    border: 2px solid #000000 !important;
    border-radius: 8px !important;
    font-weight: 600 !important;
    padding: 0.75rem 1.5rem !important;
    transition: all 0.3s ease !important;
}

.swal2-cancel:hover {
    background-color: #f8f9fa !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1) !important;
}

.swal2-icon.swal2-success {
    border-color: #22c55e !important;
    color: #22c55e !important;
}

.swal2-icon.swal2-error {
    border-color: #ef4444 !important;
    color: #ef4444 !important;
}

.swal2-icon.swal2-warning {
    border-color: #f59e0b !important;
    color: #f59e0b !important;
}

.swal2-toast {
    border-radius: 8px !important;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
}

.phoenix-btn-danger {
    background-color: #ef4444 !important;
    border: none !important;
    border-radius: 8px !important;
    font-weight: 600 !important;
    padding: 0.75rem 1.5rem !important;
    transition: all 0.3s ease !important;
}

.phoenix-btn-danger:hover {
    background-color: #dc2626 !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 8px rgba(239, 68, 68, 0.3) !important;
}

.phoenix-btn-secondary {
    background-color: #ffffff !important;
    color: #6b7280 !important;
    border: 2px solid #e5e7eb !important;
    border-radius: 8px !important;
    font-weight: 600 !important;
    padding: 0.75rem 1.5rem !important;
    transition: all 0.3s ease !important;
}

.phoenix-btn-secondary:hover {
    background-color: #f9fafb !important;
    border-color: #d1d5db !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1) !important;
}

/* Modern Admin Product Listing - Professional Black/White Theme */

/* Base Styles */
* {
    box-sizing: border-box;
}

/* Main Container */
.modern-admin-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    background: #ffffff;
    min-height: calc(100vh - 64px);
}

/* Page Header */
.admin-page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px solid #000000;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
}

.header-left {
    flex: 1;
}

.page-title {
    color: #000000;
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
    letter-spacing: -0.025em;
}

.page-title i {
    font-size: 2rem;
}

.page-subtitle {
    color: #666666;
    font-size: 1.125rem;
    margin: 0;
    font-weight: 400;
}

.header-actions {
    display: flex;
    gap: 1rem;
}

/* Modern Buttons */
.modern-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
}

.modern-btn-primary {
    background: #000000;
    color: #ffffff;
    border-color: #000000;
}

.modern-btn-primary:hover {
    background: #333333;
    border-color: #333333;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    color: #ffffff;
    text-decoration: none;
}

.modern-btn-secondary {
    background: #ffffff;
    color: #666666;
    border-color: #e5e5e5;
}

.modern-btn-secondary:hover {
    background: #f8f9fa;
    border-color: #000000;
    color: #000000;
    text-decoration: none;
}

/* Admin Cards */
.admin-card {
    background: #ffffff;
    border: 2px solid #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.admin-card:hover {
    border-color: #000000;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

.card-header {
    background: #000000;
    color: #ffffff;
    padding: 1.5rem 2rem;
    border-bottom: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.card-body {
    padding: 2rem;
}

/* Search and Filter */
.search-filter-container {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: end;
}

.search-section {
    width: 100%;
}

.search-form {
    width: 100%;
}

.search-group {
    display: flex;
    gap: 1rem;
    align-items: center;
}

.search-input-container {
    position: relative;
    flex: 1;
}

.search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #666666;
    font-size: 1.125rem;
    z-index: 2;
}

.modern-input {
    width: 100%;
    padding: 1rem 1rem 1rem 3rem;
    border: 2px solid #e5e5e5;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #ffffff;
}

.modern-input:focus {
    outline: none;
