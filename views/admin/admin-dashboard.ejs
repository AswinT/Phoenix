<%- include("../partials/admin/sidebar") %>

      <!-- Ultra-Modern Main Content -->
      <main class="main-content">
        <!-- Modern Header -->
        <header class="content-header">
          <div class="header-content">
            <div>
              <h1 class="page-title">Dashboard</h1>
              <p class="page-subtitle">Welcome back! Here's what's happening with your Phoenix store.</p>
            </div>
            <div class="header-actions">
              <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="search-input" placeholder="Search anything...">
              </div>
              <button class="btn btn-primary">
                <i class="fas fa-plus"></i>
                <span>New Product</span>
              </button>
            </div>
          </div>
        </header>

        <!-- Modern Content Body -->
        <div class="content-body">
          <!-- Ultra-Modern Stats Grid -->
          <div class="stats-grid">
            <div class="stat-card animate-fade-in">
              <div class="stat-header">
                <div class="stat-icon users">
                  <i class="fas fa-users"></i>
                </div>
                <div class="stat-trend up">
                  <i class="fas fa-arrow-up"></i>
                  <span>+12%</span>
                </div>
              </div>
              <div class="stat-content">
                <h3 id="totalUsers">5</h3>
                <p>Total Users</p>
              </div>
            </div>

            <div class="stat-card animate-fade-in">
              <div class="stat-header">
                <div class="stat-icon products">
                  <i class="fas fa-headphones"></i>
                </div>
                <div class="stat-trend up">
                  <i class="fas fa-arrow-up"></i>
                  <span>+8%</span>
                </div>
              </div>
              <div class="stat-content">
                <h3 id="totalProducts">20</h3>
                <p>Total Products</p>
              </div>
            </div>

            <div class="stat-card animate-fade-in">
              <div class="stat-header">
                <div class="stat-icon orders">
                  <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-trend up">
                  <i class="fas fa-arrow-up"></i>
                  <span>+15%</span>
                </div>
              </div>
              <div class="stat-content">
                <h3 id="totalOrders">0</h3>
                <p>Total Orders</p>
              </div>
            </div>

            <div class="stat-card animate-fade-in">
              <div class="stat-header">
                <div class="stat-icon revenue">
                  <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-trend up">
                  <i class="fas fa-arrow-up"></i>
                  <span>+23%</span>
                </div>
              </div>
              <div class="stat-content">
                <h3 id="totalRevenue">₹0</h3>
                <p>Total Revenue</p>
              </div>
            </div>
          </div>

          <!-- Ultra-Modern Chart Container -->
          <div class="chart-container animate-slide-up">
            <div class="chart-header">
              <div>
                <h2 class="chart-title">Sales Analytics</h2>
                <p class="chart-subtitle">Track your Phoenix headphones sales performance</p>
              </div>
              <div class="chart-actions">
                <button class="chart-filter active">7 Days</button>
                <button class="chart-filter">30 Days</button>
                <button class="chart-filter">90 Days</button>
                <button class="chart-filter">1 Year</button>
              </div>
            </div>
            <div class="chart-body">
              <canvas id="salesChart"></canvas>
            </div>
          </div>

          <!-- Modern Quick Actions Grid -->
          <div class="stats-grid">
            <div class="card animate-fade-in">
              <div class="card-body">
                <h3 style="font-family: var(--font-brand); color: var(--phoenix-primary); margin-bottom: var(--space-4);">
                  <i class="fas fa-bolt" style="color: var(--phoenix-accent); margin-right: var(--space-2);"></i>
                  Quick Actions
                </h3>
                <div style="display: flex; flex-direction: column; gap: var(--space-3);">
                  <a href="/admin/products" class="btn btn-secondary" style="justify-content: flex-start;">
                    <i class="fas fa-headphones"></i>
                    <span>Manage Products</span>
                  </a>
                  <a href="/admin/users" class="btn btn-secondary" style="justify-content: flex-start;">
                    <i class="fas fa-users"></i>
                    <span>Manage Users</span>
                  </a>
                  <a href="/get-category" class="btn btn-secondary" style="justify-content: flex-start;">
                    <i class="fas fa-tags"></i>
                    <span>Manage Categories</span>
                  </a>
                </div>
              </div>
            </div>

            <div class="card animate-fade-in">
              <div class="card-body">
                <h3 style="font-family: var(--font-brand); color: var(--phoenix-primary); margin-bottom: var(--space-4);">
                  <i class="fas fa-chart-pie" style="color: var(--phoenix-accent); margin-right: var(--space-2);"></i>
                  Recent Activity
                </h3>
                <div style="display: flex; flex-direction: column; gap: var(--space-3);">
                  <div style="display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3); background: var(--neutral-50); border-radius: var(--radius-lg);">
                    <div class="table-avatar">A</div>
                    <div>
                      <p style="margin: 0; font-weight: var(--font-medium); color: var(--neutral-800);">Admin logged in</p>
                      <p style="margin: 0; font-size: var(--text-sm); color: var(--neutral-600);">Just now</p>
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3); background: var(--neutral-50); border-radius: var(--radius-lg);">
                    <div class="table-avatar" style="background: var(--success);">S</div>
                    <div>
                      <p style="margin: 0; font-weight: var(--font-medium); color: var(--neutral-800);">System initialized</p>
                      <p style="margin: 0; font-size: var(--text-sm); color: var(--neutral-600);">5 minutes ago</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Set Dashboard as active by default
        document.querySelector('[data-route="dashboard"]')?.classList.add('active');

        // Animate stats cards with counting effect
        function animateCounter(element, target) {
          let current = 0;
          const increment = target / 50;
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              current = target;
              clearInterval(timer);
            }
            element.textContent = Math.floor(current);
          }, 30);
        }

        // Animate the stats
        setTimeout(() => {
          animateCounter(document.getElementById('totalUsers'), 5);
          animateCounter(document.getElementById('totalProducts'), 20);
          animateCounter(document.getElementById('totalOrders'), 0);
        }, 500);

        // Chart filter functionality
        const chartFilters = document.querySelectorAll('.chart-filter');
        chartFilters.forEach(filter => {
          filter.addEventListener('click', function() {
            chartFilters.forEach(f => f.classList.remove('active'));
            this.classList.add('active');
          });
        });
      });
    </script>
    </body>
    </html>
