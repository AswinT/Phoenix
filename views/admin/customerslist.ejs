<script>
// Phoenix Admin Customer Management - Modern JavaScript

document.addEventListener('DOMContentLoaded', function() {
    initializeSearchValidation();
    initializeFilterFunctionality();
    initializeTableAnimations();
});

// Initialize search input validation
function initializeSearchValidation() {
    const searchInput = document.querySelector('.search-input');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            // Remove any non-alphanumeric characters except spaces, @, and .
            this.value = this.value.replace(/[^a-zA-Z0-9\s@._-]/g, '');
        });
    }
}

// Initialize filter functionality
function initializeFilterFunctionality() {
    const statusFilter = document.getElementById('statusFilter');
    if (statusFilter) {
        // Set current filter value from URL
        const urlParams = new URLSearchParams(window.location.search);
        const currentStatus = urlParams.get('status');
        if (currentStatus) {
            statusFilter.value = currentStatus;
        }
    }
}

// Initialize table animations
function initializeTableAnimations() {
    const tableRows = document.querySelectorAll('.table-row');
    tableRows.forEach((row, index) => {
        row.style.animationDelay = `${index * 0.05}s`;
        row.classList.add('fade-in-up');
    });
}

// Filter by status
function filterByStatus(status) {
    const url = new URL(window.location);
    if (status) {
        url.searchParams.set('status', status);
    } else {
        url.searchParams.delete('status');
    }
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
}

// Export customers data
function exportCustomers() {
    Swal.fire({
        title: 'Export Customer Data',
        text: 'Choose export format for customer data',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Export as CSV',
        cancelButtonText: 'Cancel',
        showDenyButton: true,
        denyButtonText: 'Export as Excel',
        customClass: {
            popup: 'phoenix-alert',
            confirmButton: 'phoenix-btn-primary',
            cancelButton: 'phoenix-btn-secondary',
            denyButton: 'phoenix-btn-secondary'
        }
    }).then((result) => {
        if (result.isConfirmed) {
            exportAsCSV();
        } else if (result.isDenied) {
            exportAsExcel();
        }
    });
}

// Export as CSV (placeholder)
function exportAsCSV() {
    Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'info',
        title: 'CSV export functionality will be implemented soon!',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true
    });
}

// Export as Excel (placeholder)
function exportAsExcel() {
    Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'info',
        title: 'Excel export functionality will be implemented soon!',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true
    });
}

// Toggle customer block/unblock status
async function toggleCustomerStatus(customerId, customerName, shouldBlock) {
    const action = shouldBlock ? 'block' : 'unblock';
    const actionTitle = action.charAt(0).toUpperCase() + action.slice(1);

    const result = await Swal.fire({
        title: `${actionTitle} Customer`,
        html: `
            <div style="text-align: center; margin: 1rem 0;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">
                    ${shouldBlock ? '🚫' : '✅'}
                </div>
                <p style="font-size: 1.1rem; margin-bottom: 0.5rem;">
                    Are you sure you want to <strong>${action}</strong> this customer?
                </p>
                <p style="color: #6c757d; margin: 0;">
                    <strong>${customerName}</strong>
                </p>
            </div>
        `,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: `Yes, ${action}!`,
        cancelButtonText: 'Cancel',
        customClass: {
            popup: 'phoenix-alert',
            confirmButton: 'phoenix-btn-primary',
            cancelButton: 'phoenix-btn-secondary'
        },
        showClass: {
            popup: 'animate__animated animate__fadeInDown'
        },
        hideClass: {
            popup: 'animate__animated animate__fadeOutUp'
        }
    });

    if (!result.isConfirmed) {
        return;
    }

    // Show loading state
    Swal.fire({
        title: `${actionTitle}ing Customer...`,
        html: 'Please wait while we update the customer status.',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });

    try {
        const response = await fetch(`/admin/customer-block-unblock/${customerId}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ isBlocked: shouldBlock })
        });

        const result = await response.json();

        if (result.success) {
            // Success notification
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: `Customer ${action}ed successfully!`,
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                customClass: {
                    popup: 'phoenix-toast'
                }
            });

            // Reload page after short delay
            setTimeout(() => location.reload(), 1000);
        } else {
            // Error notification
            Swal.fire({
                icon: 'error',
                title: 'Update Failed',
                text: result.message || 'Failed to update customer status',
                confirmButtonText: 'OK',
                customClass: {
                    popup: 'phoenix-alert',
                    confirmButton: 'phoenix-btn-primary'
                }
            });
        }
    } catch (error) {
        // Network error notification
        Swal.fire({
            icon: 'error',
            title: 'Network Error',
            text: 'Error updating customer status. Please try again.',
            confirmButtonText: 'OK',
            customClass: {
                popup: 'phoenix-alert',
                confirmButton: 'phoenix-btn-primary'
            }
        });
        console.error('Customer status update error:', error);
    }
}

// Contact customer modal
function contactCustomer(email, mobile) {
    Swal.fire({
        title: 'Contact Customer',
        html: `
            <div style="text-align: left; margin: 1rem 0;">
                <div style="margin-bottom: 1rem; padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                    <h6 style="margin: 0 0 0.5rem 0; color: #000000;">
                        <i class="bi bi-envelope" style="margin-right: 0.5rem;"></i>
                        Email Address
                    </h6>
                    <a href="mailto:${email}" style="color: #000000; text-decoration: none; font-weight: 600;">
                        ${email}
                    </a>
                </div>

                ${mobile ? `
                    <div style="margin-bottom: 1rem; padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                        <h6 style="margin: 0 0 0.5rem 0; color: #000000;">
                            <i class="bi bi-telephone" style="margin-right: 0.5rem;"></i>
                            Phone Number
                        </h6>
                        <a href="tel:+91${mobile}" style="color: #000000; text-decoration: none; font-weight: 600;">
                            +91 ${mobile}
                        </a>
                    </div>

                    <div style="padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                        <h6 style="margin: 0 0 0.5rem 0; color: #000000;">
                            <i class="bi bi-whatsapp" style="margin-right: 0.5rem;"></i>
                            WhatsApp
                        </h6>
                        <a href="https://wa.me/91${mobile}" target="_blank" style="color: #25d366; text-decoration: none; font-weight: 600;">
                            Send WhatsApp Message
                        </a>
                    </div>
                ` : `
                    <div style="padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                        <h6 style="margin: 0 0 0.5rem 0; color: #000000;">
                            <i class="bi bi-telephone" style="margin-right: 0.5rem;"></i>
                            Phone Number
                        </h6>
                        <span style="color: #6c757d; font-style: italic;">Not provided</span>
                    </div>
                `}
            </div>
        `,
        confirmButtonText: 'Close',
        customClass: {
            popup: 'phoenix-alert',
            confirmButton: 'phoenix-btn-primary'
        },
        showClass: {
            popup: 'animate__animated animate__fadeInDown'
        },
        hideClass: {
            popup: 'animate__animated animate__fadeOutUp'
        }
    });
}

// Add CSS animations
const style = document.createElement('style');
style.textContent = `
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in-up {
        animation: fadeInUp 0.6s ease-out forwards;
    }

    .phoenix-toast {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    }
`;
document.head.appendChild(style);
</script>
