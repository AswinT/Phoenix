    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #ffffff;
}

.stat-icon.customers {
    background: linear-gradient(135deg, #000000, #333333);
}

.stat-icon.active {
    background: linear-gradient(135deg, #22c55e, #16a34a);
}

.stat-icon.blocked {
    background: linear-gradient(135deg, #ef4444, #dc2626);
}

.stat-icon.new {
