    z-index: 1;
}

.modern-admin-container {
    max-width: 1400px;
    margin: 0 auto;
}

/* ===== PAGE HEADER ===== */
.admin-page-header {
    background: #000000;
    color: #ffffff;
    padding: 2rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
