<%- include('../partials/admin/_adminHeader.ejs') %>
<%- include("../partials/admin/_adminSidebar.ejs") %>

<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="admin-content">
    <div class="modern-admin-container">
        <!-- Page Header -->
        <div class="admin-page-header">
            <div class="header-content">
                <div class="header-left">
                    <h1 class="page-title">
                        <i class="bi bi-people"></i>
                        Customer Management
                    </h1>
                    <p class="page-subtitle">Manage Phoenix headphone store customers</p>
                </div>
                <div class="header-actions">
                    <div class="search-container">
                        <form action="/admin/customers" method="GET" class="search-form">
                            <div class="search-input-group">
                                <i class="bi bi-search search-icon"></i>
                                <input type="text"
                                       class="search-input"
                                       name="search"
                                       placeholder="Search customers by name or email..."
                                       value="<%= searchQuery %>">
                                <button type="submit" class="search-btn">
                                    <i class="bi bi-search"></i>
                                </button>
                                <% if (searchQuery) { %>
                                    <a href="/admin/customers" class="clear-search-btn">
                                        <i class="bi bi-x"></i>
                                    </a>
                                <% } %>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="filter-card">
                <div class="filter-content">
                    <label for="statusFilter" class="filter-label">
                        <i class="bi bi-funnel"></i>
                        Filter by Status
                    </label>
                    <select id="statusFilter" class="filter-select" onchange="filterByStatus(this.value)">
                        <option value="">All Customers</option>
                        <option value="active">Active Only</option>
                        <option value="blocked">Blocked Only</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Statistics Grid -->
        <div class="stats-grid">
            <div class="modern-stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon customers">
                        <i class="bi bi-people"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-arrow-up text-success"></i>
                    </div>
                </div>
                <div class="stat-content">
                    <div class="stat-value"><%= users.length %></div>
                    <div class="stat-label">Customers Shown</div>
                    <div class="stat-description">Currently displayed</div>
                </div>
            </div>

            <div class="modern-stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon active">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-arrow-up text-success"></i>
                    </div>
                </div>
                <div class="stat-content">
                    <div class="stat-value"><%= users.filter(u => !u.isBlocked).length %></div>
                    <div class="stat-label">Active Customers</div>
                    <div class="stat-description">Currently active</div>
                </div>
            </div>

            <div class="modern-stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon blocked">
                        <i class="bi bi-x-circle"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-arrow-down text-danger"></i>
                    </div>
                </div>
                <div class="stat-content">
                    <div class="stat-value"><%= users.filter(u => u.isBlocked).length %></div>
                    <div class="stat-label">Blocked Customers</div>
                    <div class="stat-description">Currently blocked</div>
                </div>
            </div>

            <div class="modern-stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon new">
                        <i class="bi bi-calendar-plus"></i>
                    </div>
                    <div class="stat-trend">
                        <i class="bi bi-arrow-up text-success"></i>
                    </div>
                </div>
                <div class="stat-content">
                    <div class="stat-value"><%= users.filter(u => new Date(u.createdAt) > new Date(Date.now() - 30*24*60*60*1000)).length %></div>
                    <div class="stat-label">New Customers</div>
                    <div class="stat-description">Last 30 days</div>
                </div>
            </div>
        </div>

        <!-- Customers Table Card -->
        <div class="modern-table-card">
            <div class="table-card-header">
                <h3 class="table-title">
                    <i class="bi bi-table"></i>
                    Customer Database
                </h3>
                <div class="table-actions">
                    <button class="modern-btn modern-btn-secondary" onclick="exportCustomers()">
                        <i class="bi bi-download"></i>
                        Export
                    </button>
                </div>
            </div>
            <div class="table-card-content">
                <div class="modern-table-container">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Customer Name</th>
                                <th>Email</th>
                                <th>Mobile</th>
                                <th>Joined Date</th>
                                <th>Account Type</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (users && users.length > 0) { %>
                                <% users.forEach((user, index) => { %>
                                    <tr class="table-row">
                                        <!-- Serial Number -->
                                        <td class="serial-cell">
                                            <span class="serial-number"><%= (currentPage - 1) * 10 + index + 1 %></span>
                                        </td>

                                        <!-- Customer Name -->
                                        <td class="customer-cell">
                                            <div class="customer-info">
                                                <div class="customer-avatar">
                                                    <%= user.fullname.charAt(0).toUpperCase() %>
                                                </div>
                                                <div class="customer-details">
                                                    <div class="customer-name"><%= user.fullname %></div>
                                                    <% if (user.googleId) { %>
                                                        <div class="customer-type">
                                                            <i class="bi bi-google"></i>
                                                            Google Account
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Email -->
                                        <td class="email-cell">
                                            <a href="mailto:<%= user.email %>" class="email-link">
                                                <%= user.email %>
                                            </a>
                                        </td>

                                        <!-- Mobile -->
                                        <td class="mobile-cell">
                                            <% if (user.mobile) { %>
                                                <a href="tel:+91<%= user.mobile %>" class="mobile-link">
                                                    +91 <%= user.mobile %>
                                                </a>
                                            <% } else { %>
                                                <span class="mobile-empty">Not provided</span>
                                            <% } %>
                                        </td>

                                        <!-- Joined Date -->
                                        <td class="date-cell">
                                            <div class="date-info">
                                                <div class="date-primary">
                                                    <%= user.createdAt.toLocaleDateString('en-IN', {
                                                        day: 'numeric',
                                                        month: 'short',
                                                        year: 'numeric'
                                                    }) %>
                                                </div>
                                                <div class="date-secondary">
                                                    <%= user.createdAt.toLocaleTimeString('en-IN', {
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    }) %>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- Account Type -->
                                        <td class="type-cell">
                                            <% if (user.googleId) { %>
                                                <span class="modern-badge badge-google">
                                                    <i class="bi bi-google"></i>
                                                    Google
                                                </span>
                                            <% } else { %>
                                                <span class="modern-badge badge-email">
                                                    <i class="bi bi-envelope"></i>
                                                    Email
                                                </span>
                                            <% } %>
                                        </td>

                                        <!-- Status -->
                                        <td class="status-cell">
                                            <% if (user.isBlocked) { %>
                                                <span class="modern-badge badge-blocked">
                                                    <i class="bi bi-x-circle"></i>
                                                    Blocked
                                                </span>
                                            <% } else { %>
                                                <span class="modern-badge badge-active">
                                                    <i class="bi bi-check-circle"></i>
                                                    Active
                                                </span>
                                            <% } %>
                                        </td>

                                        <!-- Actions -->
                                        <td class="actions-cell">
                                            <div class="action-buttons">
                                                <!-- Block/Unblock Button -->
                                                <button type="button"
                                                        class="action-btn <%= user.isBlocked ? 'action-btn-success' : 'action-btn-danger' %>"
                                                        onclick="toggleCustomerStatus('<%= user._id %>', '<%= user.fullname %>', <%= !user.isBlocked %>)"
                                                        title="<%= user.isBlocked ? 'Unblock' : 'Block' %> Customer">
                                                    <i class="bi bi-<%= user.isBlocked ? 'check-circle' : 'x-circle' %>"></i>
                                                </button>

                                                <!-- Contact Button -->
                                                <button type="button"
                                                        class="action-btn action-btn-secondary"
                                                        onclick="contactCustomer('<%= user.email %>', '<%= user.mobile %>')"
                                                        title="Contact Customer">
                                                    <i class="bi bi-telephone"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="empty-state">
                                        <div class="empty-content">
                                            <div class="empty-icon">
                                                <i class="bi bi-people"></i>
                                            </div>
                                            <h5 class="empty-title">No customers found</h5>
                                            <p class="empty-description">
                                                <% if (searchQuery) { %>
                                                    No customers match your search criteria.
                                                    <a href="/admin/customers" class="empty-link">Clear search</a> to see all customers.
                                                <% } else { %>
                                                    Your Phoenix store doesn't have any registered customers yet.
                                                <% } %>
                                            </p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="modern-pagination">
                <div class="pagination-info">
                    <span class="pagination-text">
                        Showing <%= ((currentPage - 1) * 10) + 1 %> to <%= Math.min(currentPage * 10, users.length) %> of <%= users.length %> customers
                    </span>
                </div>
                <div class="pagination-controls">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>&search=<%= searchQuery %>" class="pagination-btn pagination-prev">
                            <i class="bi bi-chevron-left"></i>
                            Previous
                        </a>
                    <% } %>

                    <div class="pagination-numbers">
                        <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <% if (i === currentPage) { %>
                                <span class="pagination-number active"><%= i %></span>
                            <% } else { %>
                                <a href="?page=<%= i %>&search=<%= searchQuery %>" class="pagination-number"><%= i %></a>
                            <% } %>
                        <% } %>
                    </div>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>&search=<%= searchQuery %>" class="pagination-btn pagination-next">
                            Next
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contact Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="contactInfo">
                    <!-- Contact details will be populated here -->
                </div>
            </div>
        </div>
    </div>
</div>

<style>
