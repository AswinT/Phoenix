    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
    <script>
        function showSection(section) {
            // Remove active class from all menu items
            document.querySelectorAll('.menu-item').forEach(item => {
                item.classList.remove('active');
            });

            // Add active class to clicked item
            event.target.classList.add('active');

            // Hide all content sections
            document.querySelectorAll('.content-section').forEach(content => {
                content.style.display = 'none';
            });

            // Update page content based on section
            const pageTitle = document.querySelector('.page-title');
            const pageSubtitle = document.querySelector('.page-subtitle');

            switch(section) {
                case 'profile':
                    pageTitle.textContent = 'My Profile';
                    pageSubtitle.textContent = 'Manage your personal information and preferences.';
                    document.getElementById('profile-content').style.display = 'block';
                    break;
                case 'address':
                    pageTitle.textContent = 'Address Book';
                    pageSubtitle.textContent = 'Manage your saved addresses for faster checkout.';
                    // Show address content when implemented
                    break;
                case 'orders':
                    pageTitle.textContent = 'My Orders';
                    pageSubtitle.textContent = 'Track your orders and view order history.';
                    // Show orders content when implemented
                    break;
                case 'wishlist':
                    pageTitle.textContent = 'My Wishlist';
                    pageSubtitle.textContent = 'Items you\'ve saved for later purchase.';
                    // Show wishlist content when implemented
                    break;
                case 'wallet':
                    pageTitle.textContent = 'Wallet';
                    pageSubtitle.textContent = 'Manage your wallet balance and transactions.';
                    // Show wallet content when implemented
                    break;
                case 'coupons':
                    pageTitle.textContent = 'Coupons';
                    pageSubtitle.textContent = 'Your available coupons and discount codes.';
                    // Show coupons content when implemented
                    break;
                case 'referrals':
                    pageTitle.textContent = 'Referrals';
                    pageSubtitle.textContent = 'Invite friends and earn rewards.';
                    // Show referrals content when implemented
                    break;
                case 'password':
                    pageTitle.textContent = 'Change Password';
                    pageSubtitle.textContent = 'Update your account password for security.';
                    // Show password change content when implemented
                    break;
                default:
                    pageTitle.textContent = 'Dashboard';
                    pageSubtitle.textContent = 'Welcome back, <%= user.fullname || "User" %>! Here\'s what\'s happening with your account.';
                    document.getElementById('dashboard-content').style.display = 'block';
            }
        }

        // Profile photo upload functions
        function triggerPhotoUpload() {
            document.getElementById('profilePhotoInput').click();
        }

        async function uploadProfilePhoto() {
            const fileInput = document.getElementById('profilePhotoInput');
            const file = fileInput.files[0];

            if (!file) {
                return;
            }

            // Validate file type
            if (!file.type.startsWith('image/')) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid File',
                    text: 'Please select an image file.',
                    confirmButtonColor: '#111827'
                });
                return;
            }

            // Validate file size (5MB)
            if (file.size > 5 * 1024 * 1024) {
                Swal.fire({
                    icon: 'error',
                    title: 'File Too Large',
                    text: 'Please select an image smaller than 5MB.',
                    confirmButtonColor: '#111827'
                });
                return;
            }

            // Show loading
            Swal.fire({
                title: 'Uploading Photo...',
                text: 'Please wait while we upload your profile photo.',
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const formData = new FormData();
                formData.append('profilePhoto', file);

                const response = await fetch('/upload-profile-photo', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Update both sidebar and main profile images
                    const newImageUrl = `/uploads/profiles/${result.filename}`;

                    // Update sidebar
                    const sidebarContainer = document.querySelector('.profile-avatar-container');
                    sidebarContainer.innerHTML = `
                        <img src="${newImageUrl}" alt="Profile Photo" class="profile-avatar-img" id="sidebarProfileImg">
                        <div class="profile-avatar-overlay" onclick="triggerPhotoUpload()">
                            <i class="bi bi-camera"></i>
                        </div>
                    `;

                    // Update main profile section
                    const mainContainer = document.querySelector('.main-profile-photo-container');
                    mainContainer.innerHTML = `
                        <img src="${newImageUrl}" alt="Profile Photo" class="main-profile-photo" id="mainProfileImg">
                        <div class="main-profile-overlay" onclick="triggerPhotoUpload()">
                            <i class="bi bi-camera"></i>
                            <span>Change Photo</span>
                        </div>
                    `;

                    Swal.fire({
                        icon: 'success',
                        title: 'Photo Updated!',
                        text: result.message,
                        confirmButtonColor: '#111827'
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Upload Failed',
                        text: result.message,
                        confirmButtonColor: '#111827'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Upload Error',
                    text: 'Something went wrong. Please try again.',
                    confirmButtonColor: '#111827'
                });
            }

            // Clear the file input
            fileInput.value = '';
        }
    </script>

