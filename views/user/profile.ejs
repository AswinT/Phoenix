<%- include('../partials/user/header') %>

<!-- Modern Design System Integration -->
<link href="/styles/modern-design-system.css" rel="stylesheet">
<link href="/styles/modern-components.css" rel="stylesheet">
<link href="/styles/animations.css" rel="stylesheet">

<style>
        /* Modern Profile Page Styles */
        body {
            font-family: var(--font-primary);
            background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-100) 100%);
            color: var(--gray-900);
            margin: 0;
            padding: 0;
        }

        .profile-container {
            display: flex;
            min-height: 100vh;
            padding-top: var(--space-24); /* Account for navbar */
        }

        /* Modern Sidebar Styles */
        .sidebar {
            width: 320px;
            background: var(--white);
            box-shadow: var(--shadow-2xl);
            padding: var(--space-8) 0;
            position: fixed;
            height: calc(100vh - var(--space-24));
            top: var(--space-24);
            left: 0;
            overflow-y: auto;
            z-index: 1000;
            border-right: 1px solid var(--gray-200);
            position: relative;
        }

        .sidebar::before {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(180deg, var(--accent-gold), var(--accent-blue));
        }

        .profile-section {
            text-align: center;
            padding: var(--space-8);
            border-bottom: 1px solid var(--gray-200);
            margin-bottom: var(--space-8);
            background: linear-gradient(135deg, var(--gray-50), var(--white));
            position: relative;
        }

        .profile-section::before {
            content: "♪";
            position: absolute;
            top: var(--space-4);
            right: var(--space-4);
            font-size: var(--text-lg);
            color: var(--accent-gold);
            opacity: 0.7;
        }

        .profile-avatar-container {
            position: relative;
            width: 80px;
            height: 80px;
            margin: 0 auto var(--space-4);
            cursor: pointer;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-900), var(--primary-800));
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--text-2xl);
            color: var(--white);
            font-weight: var(--font-bold);
            font-family: var(--font-brand);
            box-shadow: var(--shadow-lg);
            border: 3px solid var(--accent-gold);
        }

        .profile-avatar-img {
            width: 80px;
            height: 80px;
            border-radius: var(--radius-full);
            object-fit: cover;
            box-shadow: var(--shadow-lg);
            border: 3px solid var(--accent-gold);
        }

        .profile-avatar-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all var(--transition-base);
            color: var(--white);
            font-size: var(--text-lg);
            backdrop-filter: blur(4px);
        }

        .profile-avatar-container:hover .profile-avatar-overlay {
            opacity: 1;
            transform: scale(1.05);
        }

        .profile-photo-upload {
            display: none;
        }

        /* Main Profile Photo Styles */
        .main-profile-photo-container {
            position: relative;
            width: 140px;
            height: 140px;
            margin: 0 auto;
            cursor: pointer;
        }

        .main-profile-photo {
            width: 140px;
            height: 140px;
            border-radius: var(--radius-full);
            object-fit: cover;
            box-shadow: var(--shadow-2xl);
            border: 4px solid var(--accent-gold);
            transition: all var(--transition-base);
        }

        .main-profile-avatar {
            width: 140px;
            height: 140px;
            background: linear-gradient(135deg, var(--primary-900), var(--primary-800));
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--text-5xl);
            color: var(--white);
            font-weight: var(--font-bold);
            font-family: var(--font-brand);
            box-shadow: var(--shadow-2xl);
            border: 4px solid var(--accent-gold);
            transition: all var(--transition-base);
        }

        .main-profile-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            border-radius: var(--radius-full);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all var(--transition-base);
            color: var(--white);
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
            font-family: var(--font-primary);
            backdrop-filter: blur(4px);
        }

        .main-profile-overlay i {
            font-size: var(--text-2xl);
            margin-bottom: var(--space-2);
        }

        .main-profile-photo-container:hover .main-profile-overlay {
            opacity: 1;
        }

        .main-profile-photo-container:hover .main-profile-photo,
        .main-profile-photo-container:hover .main-profile-avatar {
            transform: scale(1.05);
        }

        .profile-name {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            font-family: var(--font-primary);
            color: var(--primary-900);
            margin-bottom: var(--space-2);
        }

        .profile-email {
            font-size: var(--text-sm);
            color: var(--gray-600);
            font-weight: var(--font-medium);
        }

        .menu-section h3 {
            padding: 0 var(--space-8) var(--space-4);
            font-size: var(--text-base);
            font-weight: var(--font-bold);
            font-family: var(--font-primary);
            color: var(--primary-900);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }

        .menu-section h3::before {
            content: "⚙";
            color: var(--accent-gold);
            font-size: var(--text-lg);
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: var(--space-4) var(--space-8);
            color: var(--gray-600);
            text-decoration: none;
            transition: all var(--transition-base);
            cursor: pointer;
            font-family: var(--font-primary);
            font-weight: var(--font-medium);
            position: relative;
        }

        .menu-item::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: var(--accent-gold);
            transform: scaleY(0);
            transition: transform var(--transition-base);
        }

        .menu-item:hover {
            background: var(--gray-50);
            color: var(--primary-900);
            transform: translateX(4px);
        }

        .menu-item:hover::before {
            transform: scaleY(1);
        }

        .menu-item.active {
            background: linear-gradient(135deg, var(--primary-900), var(--primary-800));
            color: var(--white);
            border-radius: var(--radius-lg);
            margin: 0 var(--space-4);
            box-shadow: var(--shadow-md);
        }

        .menu-item.active::before {
            display: none;
        }

        /* Main Content Styles */
        .main-content {
            flex: 1;
            margin-left: 320px;
            padding: var(--space-12);
            min-height: calc(100vh - var(--space-24));
        }

        .page-header {
            margin-bottom: var(--space-12);
            padding: var(--space-8);
            background: var(--white);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--gray-200);
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-blue));
        }

        .page-title {
            font-family: var(--font-brand);
            font-size: var(--text-3xl);
            font-weight: var(--font-bold);
            color: var(--primary-900);
            margin-bottom: var(--space-2);
            letter-spacing: -0.025em;
            display: flex;
            align-items: center;
            gap: var(--space-3);
        }

        .page-title::before {
            content: "👤";
            font-size: var(--text-2xl);
            color: var(--accent-gold);
        }

        .page-subtitle {
            color: var(--gray-600);
            font-size: var(--text-base);
            font-family: var(--font-primary);
            line-height: var(--leading-relaxed);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: var(--space-8);
            margin-bottom: var(--space-12);
        }

        .card {
            background: var(--white);
            border-radius: var(--radius-2xl);
            padding: var(--space-8);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--gray-200);
            transition: all var(--transition-base);
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-blue));
            opacity: 0;
            transition: opacity var(--transition-base);
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-2xl);
            border-color: var(--accent-gold);
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-header {
            display: flex;
            align-items: center;
            margin-bottom: var(--space-6);
        }

        .card-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-gold-dark));
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: var(--space-4);
            color: var(--white);
            font-size: var(--text-xl);
            box-shadow: var(--shadow-md);
        }

        .card-title {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            font-family: var(--font-primary);
            color: var(--primary-900);
        }

        .card-content {
            color: var(--gray-600);
            line-height: var(--leading-relaxed);
            font-family: var(--font-primary);
        }

        .stats-number {
            font-family: var(--font-brand);
            font-size: var(--text-4xl);
            font-weight: var(--font-bold);
            color: var(--primary-900);
            margin-bottom: var(--space-2);
            background: linear-gradient(135deg, var(--primary-900), var(--accent-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .recent-activity {
            background: var(--white);
            border-radius: var(--radius-2xl);
            padding: var(--space-8);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--gray-200);
            position: relative;
            overflow: hidden;
        }

        .recent-activity::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-blue));
        }

        .activity-header {
            font-family: var(--font-primary);
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-6);
            color: var(--primary-900);
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }

        .activity-header::before {
            content: "📊";
            font-size: var(--text-lg);
            color: var(--accent-gold);
        }

        .activity-item {
            display: flex;
            align-items: center;
            padding: var(--space-4) 0;
            border-bottom: 1px solid var(--gray-200);
            transition: all var(--transition-base);
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-item:hover {
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            padding-left: var(--space-4);
            padding-right: var(--space-4);
        }

        .activity-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-gold-dark));
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: var(--space-4);
            font-size: var(--text-sm);
            color: var(--white);
            box-shadow: var(--shadow-sm);
        }

        .activity-details {
            flex: 1;
        }

        .activity-title {
            font-family: var(--font-primary);
            font-weight: var(--font-medium);
            color: var(--gray-900);
            margin-bottom: var(--space-1);
        }

        .activity-time {
            font-size: var(--text-xs);
            color: var(--gray-500);
            font-weight: var(--font-medium);
        }

        .btn {
            background: linear-gradient(135deg, var(--primary-900), var(--primary-800));
            color: var(--white);
            border: none;
            padding: var(--space-4) var(--space-8);
            border-radius: var(--radius-lg);
            font-weight: var(--font-semibold);
            font-family: var(--font-primary);
            cursor: pointer;
            transition: all var(--transition-base);
            box-shadow: var(--shadow-md);
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn-outline {
            background: transparent;
            color: var(--primary-900);
            border: 2px solid var(--primary-900);
            box-shadow: var(--shadow-sm);
        }

        .btn-outline:hover {
            background: var(--primary-900);
            color: var(--white);
            transform: translateY(-2px);
        }

        .content-section {
            display: block;
        }

        .content-section.hidden {
            display: none;
        }

        /* Modern Form Styles */
        .form-group-modern {
            margin-bottom: var(--space-6);
        }

        .form-label-modern {
            display: block;
            margin-bottom: var(--space-2);
            font-family: var(--font-primary);
            font-weight: var(--font-semibold);
            color: var(--gray-700);
            font-size: var(--text-sm);
        }

        .form-input-modern {
            width: 100%;
            padding: var(--space-4);
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-lg);
            font-size: var(--text-base);
            font-family: var(--font-primary);
            background-color: var(--gray-50);
            color: var(--gray-900);
            transition: all var(--transition-base);
            outline: none;
        }

        .form-input-modern:focus {
            border-color: var(--accent-gold);
            background-color: var(--white);
            box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.1);
        }

        .form-input-modern:disabled {
            background-color: var(--gray-100);
            color: var(--gray-500);
            cursor: not-allowed;
        }

        .form-input-modern::placeholder {
            color: var(--gray-400);
        }

        /* Modern Responsive Design */
        @media (max-width: 1024px) {
            .sidebar {
                width: 280px;
            }

            .main-content {
                margin-left: 280px;
                padding: var(--space-8);
            }
        }

        @media (max-width: 768px) {
            .profile-container {
                padding-top: var(--space-20);
            }

            .sidebar {
                transform: translateX(-100%);
                transition: transform var(--transition-base);
                top: var(--space-20);
                height: calc(100vh - var(--space-20));
                width: 280px;
                z-index: 1001;
            }

            .sidebar.mobile-open {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
                padding: var(--space-6);
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: var(--space-6);
            }

            .page-header {
                padding: var(--space-6);
            }

            .page-title {
                font-size: var(--text-2xl);
            }

            .card {
                padding: var(--space-6);
            }
        }

        @media (max-width: 480px) {
            .profile-container {
                padding-top: var(--space-16);
            }

            .main-content {
                padding: var(--space-4);
            }

            .page-header {
                padding: var(--space-4);
            }

            .page-title {
                font-size: var(--text-xl);
                flex-direction: column;
                text-align: center;
                gap: var(--space-2);
            }

            .card {
                padding: var(--space-4);
            }

            .profile-avatar-container {
                width: 60px;
                height: 60px;
            }

            .profile-avatar,
            .profile-avatar-img {
                width: 60px;
                height: 60px;
                font-size: var(--text-lg);
            }

            .main-profile-photo-container {
                width: 100px;
                height: 100px;
            }

            .main-profile-photo,
            .main-profile-avatar {
                width: 100px;
                height: 100px;
                font-size: var(--text-3xl);
            }
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="profile-section">
                <div class="profile-avatar-container">
                    <% if (user.profilePhoto) { %>
                        <img src="/uploads/profiles/<%= user.profilePhoto %>" alt="Profile Photo" class="profile-avatar-img" id="sidebarProfileImg">
                    <% } else { %>
                        <div class="profile-avatar" id="sidebarProfileAvatar"><%= user.fullname ? user.fullname.charAt(0).toUpperCase() : '👤' %></div>
                    <% } %>
                    <div class="profile-avatar-overlay" onclick="triggerPhotoUpload()">
                        <i class="bi bi-camera"></i>
                    </div>
                </div>
                <div class="profile-name"><%= user.fullname || 'User' %></div>
                <div class="profile-email"><%= user.email || 'No email' %></div>
            </div>
            
            <div class="menu-section">
                <h3>Manage My Account</h3>
                <a href="#" class="menu-item active" onclick="showSection('profile')">My Profile</a>
                <a href="#" class="menu-item" onclick="showSection('address')">Address Book</a>
                <a href="#" class="menu-item" onclick="showSection('orders')">My Orders</a>
                <a href="#" class="menu-item" onclick="showSection('wishlist')">My Wishlist</a>
                <a href="#" class="menu-item" onclick="showSection('wallet')">Wallet</a>
                <a href="#" class="menu-item" onclick="showSection('coupons')">Coupons</a>
                <a href="#" class="menu-item" onclick="showSection('referrals')">Referrals</a>
                <a href="#" class="menu-item" onclick="showSection('password')">Change Password</a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="page-header">
                <h1 class="page-title">My Profile</h1>
                <p class="page-subtitle">Manage your personal information and preferences.</p>
            </div>

            <!-- Dashboard Content -->
            <div id="dashboard-content" class="content-section" style="display: none;">
                <div class="dashboard-grid">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Total Orders</div>
                        </div>
                        <div class="card-content">
                            <div class="stats-number">0</div>
                            <p>Orders placed this year</p>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Wishlist Items</div>
                        </div>
                        <div class="card-content">
                            <div class="stats-number">0</div>
                            <p>Items saved for later</p>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Wallet Balance</div>
                        </div>
                        <div class="card-content">
                            <div class="stats-number">₹0</div>
                            <p>Available balance</p>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">Active Coupons</div>
                        </div>
                        <div class="card-content">
                            <div class="stats-number">0</div>
                            <p>Coupons ready to use</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Content -->
            <div id="profile-content" class="content-section">
                <!-- Profile Photo Section -->
                <div class="card" style="margin-bottom: var(--space-8);">
                    <div class="card-header">
                        <div class="card-icon">📷</div>
                        <div class="card-title">Profile Photo</div>
                    </div>
                    <div class="card-content" style="text-align: center;">
                        <div class="main-profile-photo-container">
                            <% if (user.profilePhoto) { %>
                                <img src="/uploads/profiles/<%= user.profilePhoto %>" alt="Profile Photo" class="main-profile-photo" id="mainProfileImg">
                            <% } else { %>
                                <div class="main-profile-avatar" id="mainProfileAvatar"><%= user.fullname ? user.fullname.charAt(0).toUpperCase() : '👤' %></div>
                            <% } %>
                            <div class="main-profile-overlay" onclick="triggerPhotoUpload()">
                                <i class="bi bi-camera"></i>
                                <span>Change Photo</span>
                            </div>
                        </div>
                        <p style="margin-top: var(--space-4); color: var(--gray-600); font-size: var(--text-sm); font-family: var(--font-primary);">Click on the photo to upload a new profile picture</p>
                    </div>
                </div>

                <!-- Personal Information Section -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">👤</div>
                        <div class="card-title">Personal Information</div>
                    </div>
                    <div class="card-content">
                        <form id="profileForm">
                            <div class="form-group-modern">
                                <label class="form-label-modern">Full Name</label>
                                <input type="text" value="<%= user.fullname || '' %>" class="form-input-modern" name="fullname">
                            </div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Email Address</label>
                                <input type="email" value="<%= user.email || '' %>" class="form-input-modern" name="email">
                            </div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Phone Number</label>
                                <input type="tel" value="<%= user.phone || '' %>" placeholder="Enter your phone number" class="form-input-modern" name="phone">
                            </div>
                            <div class="form-group-modern">
                                <label class="form-label-modern">Account Type</label>
                                <input type="text" value="<%= user.googleId ? 'Google Account' : 'Regular Account' %>" disabled class="form-input-modern">
                            </div>
                            <button type="submit" class="btn">
                                <i class="bi bi-check-circle me-2"></i>Update Profile
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Hidden file input for photo upload -->
            <input type="file" id="profilePhotoInput" class="profile-photo-upload" accept="image/*" onchange="uploadProfilePhoto()">

            <div class="recent-activity">
                <h2 class="activity-header">Recent Activity</h2>
                
                <div class="activity-item">
                    <div class="activity-details">
                        <div class="activity-title">Order #12345 has been delivered</div>
                        <div class="activity-time">2 hours ago</div>
                    </div>
                </div>

                <div class="activity-item">
                    <div class="activity-details">
                        <div class="activity-title">Added "Wireless Headphones" to wishlist</div>
                        <div class="activity-time">1 day ago</div>
                    </div>
                </div>

                <div class="activity-item">
                    <div class="activity-details">
                        <div class="activity-title">New coupon "SAVE20" added to your account</div>
                        <div class="activity-time">3 days ago</div>
                    </div>
                </div>

                <div class="activity-item">
                    <div class="activity-details">
                        <div class="activity-title">₹500 added to wallet balance</div>
                        <div class="activity-time">1 week ago</div>
                    </div>
                </div>

                <div style="margin-top: var(--space-8); text-align: center;">
