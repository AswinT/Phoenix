<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - Phoenix</title>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link href="/styles/modern-design-system.css" rel="stylesheet" />
    <link href="/styles/modern-components.css" rel="stylesheet" />
    <link href="/styles/animations.css" rel="stylesheet" />
    <style>
      /* Modern Auth Page Styles */
      body {
        font-family: var(--font-primary);
        background: linear-gradient(
          135deg,
          var(--gray-50) 0%,
          var(--gray-100) 100%
        );
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-6);
        margin: 0;
      }

      .auth-container {
        background: var(--white);
        border-radius: var(--radius-2xl);
        box-shadow: var(--shadow-2xl);
        padding: var(--space-16);
        max-width: 500px;
        width: 100%;
        position: relative;
        overflow: hidden;
      }

      .auth-container::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(
          90deg,
          var(--accent-gold),
          var(--accent-blue)
        );
      }

      .auth-brand {
        text-align: center;
        margin-bottom: var(--space-8);
      }

      .auth-brand h1 {
        font-family: var(--font-brand);
        font-size: var(--text-3xl);
        font-weight: var(--font-bold);
        color: var(--primary-900);
        margin-bottom: var(--space-1);
        letter-spacing: -0.025em;
      }

      .auth-brand p {
        color: var(--gray-600);
        font-size: var(--text-base);
        margin: 0;
      }

      .auth-title {
        font-size: var(--text-2xl);
        font-weight: var(--font-bold);
        color: var(--gray-900);
        margin-bottom: var(--space-2);
        text-align: center;
      }

      .auth-subtitle {
        color: var(--gray-600);
        margin-bottom: var(--space-8);
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        text-align: center;
      }

      .form-group-modern {
        margin-bottom: var(--space-6);
        position: relative;
      }

      .input-wrapper-modern {
        position: relative;
      }

      .form-control-modern {
        width: 100%;
        padding: var(--space-4) var(--space-12) var(--space-4) var(--space-4);
        border: 2px solid var(--gray-200);
        border-radius: var(--radius-lg);
        font-size: var(--text-base);
        font-family: var(--font-primary);
        background-color: var(--gray-50);
        transition: all var(--transition-base);
        outline: none;
      }

      .form-control-modern:focus {
        border-color: var(--accent-gold);
        background-color: var(--white);
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.1);
      }

      .form-control-modern::placeholder {
        color: var(--gray-400);
      }

      .input-icon {
        position: absolute;
        right: var(--space-4);
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: var(--text-lg);
        pointer-events: none;
        transition: all var(--transition-base);
      }

      .form-control-modern:focus + .input-icon {
        color: var(--accent-gold);
      }

      .btn-auth {
        width: 100%;
        padding: var(--space-4);
        background: linear-gradient(
          135deg,
          var(--primary-900),
          var(--primary-800)
        );
        color: var(--white);
        border: none;
        border-radius: var(--radius-lg);
        font-size: var(--text-base);
        font-weight: var(--font-semibold);
        font-family: var(--font-primary);
        cursor: pointer;
        transition: all var(--transition-base);
        position: relative;
        overflow: hidden;
        margin-bottom: var(--space-4);
      }

      .btn-auth:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
      }

      .btn-auth:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
      }

      .btn-auth .loading-spinner {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: var(--white);
        animation: spin 1s ease-in-out infinite;
        margin-right: var(--space-2);
      }

      .auth-link {
        text-align: center;
        margin-top: var(--space-6);
      }

      .auth-link a {
        color: var(--accent-gold);
        text-decoration: none;
        font-weight: var(--font-semibold);
        transition: all var(--transition-base);
      }

      .auth-link a:hover {
        color: var(--accent-gold-dark);
        text-decoration: underline;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        body {
          padding: var(--space-4);
        }

        .auth-container {
          padding: var(--space-12);
        }

        .auth-brand h1 {
          font-size: var(--text-2xl);
        }

        .auth-title {
          font-size: var(--text-xl);
        }
      }

      @media (max-width: 576px) {
        .auth-container {
          padding: var(--space-8);
        }

        .form-control-modern,
        .btn-auth {
          padding: var(--space-3);
          font-size: var(--text-sm);
        }
      }
    </style>
  </head>
  <body>
    <div class="auth-container">
      <!-- Brand Section -->
      <div class="auth-brand">
        <h1>PHOENIX</h1>
        <p>Superior Sound</p>
      </div>

      <!-- Form Section -->
      <h2 class="auth-title">Forgot your password?</h2>
      <p class="auth-subtitle">
        Enter your registered email address and we'll send you a verification
        code to reset your password.
      </p>

      <form id="forgotPasswordForm" novalidate>
        <div class="form-group-modern">
          <div class="input-wrapper-modern">
            <input
              type="text"
              class="form-control-modern"
              placeholder="Enter your registered email"
              id="email"
              name="email"
              autocomplete="email"
            />
            <i class="bi bi-envelope input-icon"></i>
          </div>
        </div>

        <button type="submit" class="btn-auth" id="verifyButton">
          <span class="btn-text">
            <i class="bi bi-check-circle me-2"></i>Send Verification Code
          </span>
          <span
            class="loading-spinner d-none"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
      </form>

      <div class="auth-link">
        <p class="mb-0 text-muted">
          Remember your password? <a href="/login">Back to Login</a>
        </p>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Phoenix Form Validation -->
    <script src="/js/form-validation.js?v=2024061501"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Initialize Phoenix Form Validation for forgot password
        const fieldConfigs = [
          { id: 'email', required: true, rules: ['email'] }
        ];

        window.PhoenixValidator.initializeForm('forgotPasswordForm', fieldConfigs, {
          showValidationSummary: true,
          onValidSubmit: async (form, event) => {
            await handleForgotPasswordSubmission();
          }
        });
      });

      // Handle forgot password submission
      async function handleForgotPasswordSubmission() {
        const email = document.getElementById("email").value;
        const submitBtn = document.getElementById("verifyButton");
        const buttonText = submitBtn.querySelector(".btn-text");
        const spinner = submitBtn.querySelector(".loading-spinner");

        // Show loader
        submitBtn.disabled = true;
        buttonText.classList.add("d-none");
        spinner.classList.remove("d-none");

        try {
          const response = await fetch("/forgot-password", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email }),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            Swal.fire({
              icon: "success",
              title: "OTP Sent",
              text: "A 6-digit OTP has been sent to your email.",
              position: "top-end",
              toast: true,
              showConfirmButton: false,
              timer: 3000,
              timerProgressBar: true,
            });
            // Redirect to OTP verification page
            setTimeout(() => {
              window.location.href = "/forgot-verify-otp";
            }, 1000);
          } else {
            Swal.fire({
              icon: "error",
              title: "Error",
              text: data.message || "Failed to verify email.",
              position: "top-end",
              toast: true,
              showConfirmButton: false,
              timer: 3000,
              timerProgressBar: true,
            });
          }
        } catch (error) {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: "An error occurred while verifying the email.",
            position: "top-end",
            toast: true,
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
          });
        } finally {
          // Hide loader
          submitBtn.disabled = false;
          buttonText.classList.remove("d-none");
          spinner.classList.add("d-none");
        }
      }

      // Input focus effects
      document.querySelectorAll(".form-control-modern").forEach((input) => {
        input.addEventListener("focus", function () {
          this.parentElement.classList.add("focused");
        });

        input.addEventListener("blur", function () {
          this.parentElement.classList.remove("focused");
        });
      });
    </script>
  </body>
</html>
