<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Password - Phoenix</title>
    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <!-- Bootstrap Icons -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <!-- SweetAlert2 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
      rel="stylesheet"
    />
    <!-- Modern Design System -->
    <link href="/styles/modern-design-system.css" rel="stylesheet" />
    <link href="/styles/modern-components.css" rel="stylesheet" />
    <link href="/styles/animations.css" rel="stylesheet" />
    <style>
      /* Modern New Password Styles */
      body {
        font-family: var(--font-primary);
        background: linear-gradient(
          135deg,
          var(--gray-50) 0%,
          var(--gray-100) 100%
        );
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-6);
        margin: 0;
      }

      .auth-container {
        background: var(--white);
        border-radius: var(--radius-2xl);
        box-shadow: var(--shadow-2xl);
        padding: var(--space-16);
        max-width: 500px;
        width: 100%;
        position: relative;
        overflow: hidden;
      }

      .auth-container::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(
          90deg,
          var(--accent-gold),
          var(--accent-blue)
        );
      }

      .auth-brand {
        text-align: center;
        margin-bottom: var(--space-8);
      }

      .auth-brand h1 {
        font-family: var(--font-brand);
        font-size: var(--text-3xl);
        font-weight: var(--font-bold);
        color: var(--primary-900);
        margin-bottom: var(--space-1);
        letter-spacing: -0.025em;
      }

      .auth-brand p {
        color: var(--gray-600);
        font-size: var(--text-base);
        margin: 0;
      }

      .auth-title {
        font-size: var(--text-2xl);
        font-weight: var(--font-bold);
        color: var(--gray-900);
        margin-bottom: var(--space-2);
        text-align: center;
      }

      .auth-subtitle {
        color: var(--gray-600);
        margin-bottom: var(--space-8);
        font-size: var(--text-base);
        line-height: var(--leading-relaxed);
        text-align: center;
      }

      .form-group-modern {
        margin-bottom: var(--space-6);
        position: relative;
      }

      .form-label-modern {
        font-family: var(--font-primary);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--gray-700);
        margin-bottom: var(--space-2);
        display: block;
      }

      .password-wrapper-modern {
        position: relative;
      }

      .form-control-modern {
        width: 100%;
        padding: var(--space-4) var(--space-12) var(--space-4) var(--space-4);
        border: 2px solid var(--gray-200);
        border-radius: var(--radius-lg);
        font-size: var(--text-base);
        font-family: var(--font-primary);
        background-color: var(--gray-50);
        transition: all var(--transition-base);
        outline: none;
      }

      .form-control-modern:focus {
        border-color: var(--accent-gold);
        background-color: var(--white);
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.1);
      }

      .form-control-modern.is-invalid {
        border-color: var(--error);
        background-color: rgba(239, 68, 68, 0.05);
      }

      .form-control-modern.is-invalid:focus {
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
      }

      .password-toggle-modern {
        position: absolute;
        right: var(--space-4);
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        font-size: var(--text-lg);
        cursor: pointer;
        transition: all var(--transition-base);
        z-index: 10;
      }

      .password-toggle-modern:hover {
        color: var(--gray-600);
      }

      .error-message-modern {
        display: none;
        margin-top: var(--space-2);
        font-size: var(--text-sm);
        color: var(--error);
        font-weight: var(--font-medium);
      }

      .form-control-modern.is-invalid ~ .error-message-modern {
        display: block;
        animation: fadeInUp 0.3s ease-out;
      }

      .btn-auth {
        width: 100%;
        padding: var(--space-4);
        background: linear-gradient(
          135deg,
          var(--primary-900),
          var(--primary-800)
        );
        color: var(--white);
        border: none;
        border-radius: var(--radius-lg);
        font-size: var(--text-base);
        font-weight: var(--font-semibold);
        font-family: var(--font-primary);
        cursor: pointer;
        transition: all var(--transition-base);
        position: relative;
        overflow: hidden;
        margin-bottom: var(--space-4);
      }

      .btn-auth:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
      }

      .btn-auth:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
      }

      .auth-link {
        text-align: center;
        margin-top: var(--space-6);
      }

      .auth-link a {
        color: var(--accent-gold);
        text-decoration: none;
        font-weight: var(--font-semibold);
        transition: all var(--transition-base);
      }

      .auth-link a:hover {
        color: var(--accent-gold-dark);
        text-decoration: underline;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        body {
          padding: var(--space-4);
        }

        .auth-container {
          padding: var(--space-12);
        }

        .auth-brand h1 {
          font-size: var(--text-2xl);
        }

        .auth-title {
          font-size: var(--text-xl);
        }
      }

      @media (max-width: 576px) {
        .auth-container {
          padding: var(--space-8);
        }

        .form-control-modern,
        .btn-auth {
          padding: var(--space-3);
          font-size: var(--text-sm);
        }
      }
    </style>
  </head>

  <body>
    <div class="auth-container">
      <!-- Brand Section -->
      <div class="auth-brand">
        <h1>PHOENIX</h1>
        <p>Superior Sound</p>
      </div>

      <!-- Form Section -->
      <h2 class="auth-title">Create New Password</h2>
      <p class="auth-subtitle">Create a strong password for your account</p>

      <form id="newPasswordForm" novalidate>
        <div class="form-group-modern">
          <label for="newPassword" class="form-label-modern"
            >New Password</label
          >
          <div class="password-wrapper-modern">
            <input
              type="password"
              class="form-control-modern"
              id="newPassword"
              placeholder="Enter your new password"
            />
            <i
              class="bi bi-lock password-toggle-modern"
              id="newPassword-toggle"
            ></i>
          </div>
          <div class="error-message-modern" id="newPassword-error">
            Password must be at least 8 characters with uppercase, lowercase,
            number and special character
          </div>
        </div>

        <div class="form-group-modern">
          <label for="confirmPassword" class="form-label-modern"
            >Confirm Password</label
          >
          <div class="password-wrapper-modern">
            <input
              type="password"
              class="form-control-modern"
              id="confirmPassword"
              placeholder="Confirm your new password"
            />
            <i
              class="bi bi-lock password-toggle-modern"
              id="confirmPassword-toggle"
            ></i>
          </div>
          <div class="error-message-modern" id="confirmPassword-error">
            Passwords do not match
          </div>
        </div>

        <button type="submit" class="btn-auth">Update Password</button>

        <div class="auth-link">
          <p class="mb-0">
            Remember your password?
            <a href="/login">Back to Login</a>
          </p>
        </div>
      </form>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Phoenix Form Validation -->
    <script src="/js/form-validation.js"></script>

    <!-- New Password Script -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const newPasswordForm = document.getElementById("newPasswordForm");

        // Initialize Phoenix Form Validation for new password
        const fieldConfigs = [
          { id: 'newPassword', required: true, rules: ['password'] },
          { id: 'confirmPassword', required: true, rules: ['confirmPassword'], compareWith: 'newPassword' }
        ];

        window.PhoenixValidator.initializeForm('newPasswordForm', fieldConfigs, {
          showValidationSummary: true,
          onValidSubmit: async (form, event) => {
            await handleNewPasswordSubmission(event);
          }
        });

        // Password toggle functionality
        function setupPasswordToggle(inputId, toggleId) {
          const input = document.getElementById(inputId);
          const toggle = document.getElementById(toggleId);
          toggle.addEventListener("click", () => {
            const isPassword = input.type === "password";
            input.type = isPassword ? "text" : "password";
            toggle.classList.toggle("bi-eye", isPassword);
            toggle.classList.toggle("bi-lock", !isPassword);
          });
        }

        setupPasswordToggle("newPassword", "newPassword-toggle");
        setupPasswordToggle("confirmPassword", "confirmPassword-toggle");

        // Handle new password submission
        async function handleNewPasswordSubmission(event) {
          const newPassword = document.getElementById("newPassword").value;
          const confirmPassword = document.getElementById("confirmPassword").value;

          // Show loading state
          const submitBtn = event.target.querySelector('button[type="submit"]');
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML =
            '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Updating...';
          submitBtn.disabled = true;

          try {
            const response = await fetch("/reset-password", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ newPassword, confirmPassword }),
              credentials: "include",
            });

            const data = await response.json();

            if (data.success) {
              Swal.fire({
                icon: "success",
                title: "Password Updated Successfully",
                text: "Your password has been updated. You can now login with your new password.",
                confirmButtonColor: "#10b981",
                confirmButtonText: "Go to Login",
                background: "#1e1e1e",
                color: "#ffffff",
                customClass: {
                  popup: 'phoenix-validation-popup'
                }
              }).then((result) => {
                if (result.isConfirmed) {
                  window.location.href = "/login";
                }
              });
            } else {
              Swal.fire({
                toast: true,
                position: "top-end",
                icon: "error",
                title: "Update Failed",
                text: data.message || "Failed to update password.",
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: "#2d1b1b",
                color: "#ffffff",
                customClass: {
                  popup: "phoenix-toast-popup",
                }
              });
            }
          } catch (error) {
            Swal.fire({
              toast: true,
              position: "top-end",
              icon: "error",
              title: "Error",
              text: "An unexpected error occurred. Please try again later.",
              showConfirmButton: false,
              timer: 3000,
              timerProgressBar: true,
              background: "#2d1b1b",
              color: "#ffffff",
              customClass: {
                popup: "phoenix-toast-popup",
              }
            });
          } finally {
            // Reset button state in case of error
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
          }
        }
      });
    </script>
  </body>
</html>
