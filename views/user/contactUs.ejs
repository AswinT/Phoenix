<%- include("../partials/user/_header.ejs") %>

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-4 text-center mb-2">Get In Touch</h1>
            <p class="text-center text-muted mb-5">We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
            
            <div class="row">
                <!-- Contact Form -->
                <div class="col-lg-8 mb-5">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-envelope me-2"></i>
                                Send us a Message
                            </h5>
                        </div>
                        <div class="card-body">
                            <form>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="name" class="form-label">Full Name</label>
                                        <input type="text" class="form-control" id="name" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="email" class="form-label">Email Address</label>
                                        <input type="email" class="form-control" id="email" required>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="subject" class="form-label">Subject</label>
                                    <input type="text" class="form-control" id="subject" required>
                                </div>
                                <div class="mb-3">
                                    <label for="message" class="form-label">Message</label>
                                    <textarea class="form-control" id="message" rows="5" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send me-2"></i>
                                    Send Message
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="col-lg-4">
                    <h2 class="h4 mb-4">Contact Information</h2>
                    
                    <div class="mb-4">
                        <h3 class="h6 text-primary">
                            <i class="bi bi-geo-alt me-2"></i>Address
                        </h3>
                        <p class="text-muted mb-0">
                            123 Phoenix Street<br>
                            Audio District, Kerala<br>
                            India - 680001
                        </p>
                    </div>

                    <div class="mb-4">
                        <h3 class="h6 text-primary">
                            <i class="bi bi-telephone me-2"></i>Phone
                        </h3>
                        <p class="text-muted mb-0">
                            <a href="tel:+919876543210" class="text-decoration-none">+91 98765 43210</a>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h3 class="h6 text-primary">
                            <i class="bi bi-envelope me-2"></i>Email
                        </h3>
                        <p class="text-muted mb-0">
                            <a href="mailto:hello@phoenix.com" class="text-decoration-none">hello@phoenix.com</a><br>
                            <a href="mailto:support@phoenix.com" class="text-decoration-none">support@phoenix.com</a>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h3 class="h6 text-primary">
                            <i class="bi bi-clock me-2"></i>Business Hours
                        </h3>
                        <p class="text-muted mb-0">
                            Mon - Fri: 9:00 AM - 6:00 PM<br>
                            Sat: 10:00 AM - 4:00 PM<br>
                            Sun: Closed
                        </p>
                    </div>

                    <!-- Social Links -->
                    <div>
                        <h3 class="h6 text-primary mb-3">Follow Us</h3>
                        <div class="d-flex gap-2">
                            <a href="#" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-twitter"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-instagram"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-youtube"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/user/_footer.ejs") %>
